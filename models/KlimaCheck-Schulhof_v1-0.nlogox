to setup-szenario
  if not is-string? Szenario-Name [ stop ]
  if empty? trim Szenario-Name [ stop ]

  set Aktive-Geometrie-Datei (word "scenario_" trim Szenario-Name "_geom.txt")
  setup
end
; -----------------------------------------------------------------------------
; Materialisierung einzelner Patches
; -----------------------------------------------------------------------------

; ----------------------------------------------------------------------------
; build-world-from-rects
; Rekonstruiert eine Welt aus einer Liste rechteckiger Geometrieblöcke.
; ----------------------------------------------------------------------------
to build-world-from-rects [rects]
  ask patches [
    initialise-patch
    set ground-kind "Pflaster"
    set object-kind "none"
    set roof-style "none"
    set wall-style "none"
    set building-height 0
    set veg-height 0
    sync-patch-semantics
  ]

  foreach rects [r ->
    let x1 item 0 r
    let x2 item 1 r
    let y1 item 2 r
    let y2 item 3 r
    let gk item 4 r
    let ok item 5 r
    let rs item 6 r
    let ws item 7 r
    let bh item 8 r
    let vh item 9 r

    ask patches with [
      pxcor >= x1 and pxcor <= x2 and
      pycor >= y1 and pycor <= y2
    ] [
      set ground-kind gk
      set object-kind ok
      set roof-style rs
      set wall-style ws
      set building-height bh
      set veg-height vh
      sync-patch-semantics
    ]
  ]
end

; ============================================================================
; Patch-Initialisierung und semantische Materiallogik
; ----------------------------------------------------------------------------
; Dieser Block definiert die interne Bedeutung einzelner Patches. Hier werden Bodenklassen, Objekte, Dach- und Wandstile sowie deren Materialparameter und Wasserspeicher logisch konsistent gesetzt.
; ============================================================================

; ----------------------------------------------------------------------------
; initialise-patch
; Setzt alle Patchvariablen auf einen definierten Ausgangszustand, bevor die eigentliche Weltgeometrie geladen oder aufgebaut wird.
; ----------------------------------------------------------------------------
to initialise-patch  ;; patch context
set selected-area? false
  
set air-temp-local-max 25
set surface-temp-max 25
set comfort-index-max 0
set heat-dose-air 0
set heat-dose-surface 0
set heat-dose-comfort 0
set water-store-rel 0
set water-stress-true 1
  
  set ground-kind "Asphalt"
  set object-kind "none"
  set Oberfläche "Asphalt"
  set surface-temp 25
  set substrate-temp 24
  set air-temp-local 25
  set air-temp-local-next 25

  set air-temp-local-max 25
  set surface-temp-max 25
  set water-store-rel 0
  set water-stress-true 1

  set albedo 0.12
  set emissivity 0.96
  set thermal-mass 0.95
  set evap-factor 0

  set water-store 0
  set water-store-max 0
  set water-stress 0
  set wetness-factor 0

  set building-height 0
  set veg-height 0
  set roof-style "none"
  set wall-style "none"
  set shadow-level 0
  set veg-nearby 0
  set tree-nearby 0
  set wall-exposure 0
  set wall-height-local 0
  set wall-albedo-local 0.35
  set wall-green-local 0
  set enclosedness 0
  set comfort-index 0
  set temp-delta 0
  set shortwave-human 0
  set longwave-human 0
  set exposure-temp 0  
  set heat-score-step 0

  set ref-active? false
  set ref-heat-dose-comfort 0
  set ref-heat-dose-air 0
  set ref-heat-dose-surface 0
  set ref-comfort-index 0
  set ref-comfort-index-max 0
  set ref-shadow-level 0
  sync-patch-semantics
end

; ----------------------------------------------------------------------------
; sync-patch-semantics
; Stellt sicher, dass die Kombination aus Bodenklasse, Objektklasse und Stilvariablen konsistent ist und die dazugehörigen Material- und Wassereigenschaften korrekt gesetzt werden.
; ----------------------------------------------------------------------------
to sync-patch-semantics  ;; patch context
  if object-kind = "building" [
    set ground-kind "none"
    if building-height <= 0 [ set building-height Gebäudehöhe ]
    set veg-height 0
    if not member? roof-style ["normal-roof" "green-roof"] [ set roof-style "normal-roof" ]
    if not member? wall-style ["normal-wall" "green-wall"] [ set wall-style "normal-wall" ]
    apply-effective-roof-properties roof-style
    apply-water-storage-properties
    update-Oberfläche-label
    stop
  ]

  if object-kind = "tree" [
    set building-height 0
    if veg-height <= 0 [ set veg-height Baumhöhe ]
    set roof-style "none"
    set wall-style "none"
    apply-tree-properties
    apply-water-storage-properties
    update-Oberfläche-label
    stop
  ]

  if object-kind = "hedge" [
    set building-height 0
    if veg-height <= 0 [ set veg-height 3 ]
    set roof-style "none"
    set wall-style "none"
    apply-hedge-properties
    apply-water-storage-properties
    update-Oberfläche-label
    stop
  ]

  set building-height 0
  set veg-height 0
  set roof-style "none"
  set wall-style "none"
  apply-ground-properties ground-kind
  apply-water-storage-properties
  update-Oberfläche-label
end

; ----------------------------------------------------------------------------
; set-Oberfläche
; Legacy-Adapter, der eine ältere Oberflächenbezeichnung in die neue Trennung aus ground-kind und object-kind übersetzt.
; ----------------------------------------------------------------------------
to set-Oberfläche [kind]  ;; patch context
  ;; Legacy-/Kompatibilitätsadapter: interne Wahrheit liegt jetzt in ground-kind + object-kind.
  if member? kind ["Asphalt" "Pflaster" "Offenpflaster" "Sand" "Sportbelag" "Rasen"] [
    set-ground-kind kind
    set-object-kind "none"
    stop
  ]

  if kind = "Baum" [ set-object-kind "tree" stop ]
  if kind = "Hecke" [ set-object-kind "hedge" stop ]
  if kind = "Gebaeude" [ set-object-kind "building" stop ]
end

; ----------------------------------------------------------------------------
; set-ground-kind
; Setzt die Bodenklasse eines Patches und synchronisiert danach die abgeleiteten Materialeigenschaften.
; ----------------------------------------------------------------------------
to set-ground-kind [kind]  ;; patch context
  if not member? kind ["Asphalt" "Pflaster" "Offenpflaster" "Sand" "Sportbelag" "Rasen" "none"] [ stop ]
  set ground-kind kind
  sync-patch-semantics
end

; ----------------------------------------------------------------------------
; set-object-kind
; Setzt die Objektklasse eines Patches und stellt Dach-, Wand-, Vegetations- und Höhenparameter passend dazu um.
; ----------------------------------------------------------------------------
to set-object-kind [kind]  ;; patch context
  if not member? kind ["none" "building" "tree" "hedge"] [ stop ]
  set object-kind kind

  if object-kind = "building" [
    set ground-kind "none"
    if building-height <= 0 [ set building-height Gebäudehöhe ]
    set veg-height 0
    if not member? roof-style ["normal-roof" "green-roof"] [ set roof-style "normal-roof" ]
    if not member? wall-style ["normal-wall" "green-wall"] [ set wall-style "normal-wall" ]
  ]

  if object-kind = "tree" [
    if ground-kind = "none" [ set ground-kind "Rasen" ]
    set building-height 0
    set veg-height Baumhöhe
    set roof-style "none"
    set wall-style "none"
  ]

  if object-kind = "hedge" [
    if ground-kind = "none" [ set ground-kind "Rasen" ]
    set building-height 0
    set veg-height 3
    set roof-style "none"
    set wall-style "none"
  ]

  if object-kind = "none" [
    if ground-kind = "none" [ set ground-kind "Pflaster" ]
    set building-height 0
    set veg-height 0
    set roof-style "none"
    set wall-style "none"
  ]

  sync-patch-semantics
end

; ----------------------------------------------------------------------------
; apply-ground-properties
; Weist einer Bodenklasse ihre Materialparameter zu.
; ----------------------------------------------------------------------------
to apply-ground-properties [kind]  ;; patch context
  if kind = "none" [
    set albedo 0.00
    set emissivity 0.00
    set thermal-mass 0.00
    set evap-factor 0.00
    stop
  ]

  if kind = "Asphalt" [
    set albedo 0.10
    set emissivity 0.95
    set thermal-mass 0.58
    set evap-factor 0.00
    stop
  ]

if kind = "Pflaster" [
  set albedo 0.20
  set emissivity 0.94
  set thermal-mass 0.58
  set evap-factor 0.0
  stop
]
  
  if kind = "Offenpflaster" [
    set albedo 0.24
    set emissivity 0.95
    set thermal-mass 0.62
    set evap-factor 0.30
    stop
  ]

  if kind = "Sand" [
    set albedo 0.35
    set emissivity 0.92
    set thermal-mass 0.40
    set evap-factor 0.09
    stop
  ]

  
  if kind = "Sportbelag" [
    set albedo 0.14
    set emissivity 0.95
    set thermal-mass 0.48
    set evap-factor 0.00
    stop
  ]

  if kind = "Rasen" [
    set albedo 0.26
    set emissivity 0.98
    set thermal-mass 0.65
    set evap-factor 1.00
    stop
  ]
end

; ----------------------------------------------------------------------------
; apply-effective-roof-properties
; Weist einem Dachstil die effektiven Materialparameter zu.
; ----------------------------------------------------------------------------
to apply-effective-roof-properties [style]  ;; patch context
  if style = "normal-roof" [
    ;; dunkles Bitumendach:
    ;; starke kurzwellige Absorption, keine Verdunstung, geringe bis mittlere Dämpfung
    set albedo 0.10
    set emissivity 0.93
    set thermal-mass 0.35
    set evap-factor 0.00
    stop
  ]

  if style = "green-roof" [
    ;; extensives Gründach:
    ;; kühler als Bitumendach, aber flacher, trockener und weniger leistungsfähig
    ;; als bodengebundener Rasen
    set albedo 0.22
    set emissivity 0.96
    set thermal-mass 0.38
    set evap-factor 0.30
    stop
  ]
end
; ----------------------------------------------------------------------------
; apply-tree-properties
; Setzt die Materialparameter eines Baumpatches.
; ----------------------------------------------------------------------------
to apply-tree-properties  ;; patch context
  set albedo 0.18
  set emissivity 0.98
  set thermal-mass 0.32
  set evap-factor 1.15
end

; ----------------------------------------------------------------------------
; apply-hedge-properties
; Setzt die Materialparameter eines Heckenpatches.
; ----------------------------------------------------------------------------
to apply-hedge-properties  ;; patch context
  set albedo 0.18
  set emissivity 0.97
  set thermal-mass 0.30
  set evap-factor 1.10
end

; ----------------------------------------------------------------------------
; set-water-bucket
; Hilfsfunktion zum kompakten Setzen von Wasserkapazität, Feuchtefaktor und initialem Füllstand.
; ----------------------------------------------------------------------------
to set-water-bucket [max-store wetness fill-frac]  ;; patch context
  set water-store-max max-store
  set wetness-factor wetness
  set water-store fill-frac * water-store-max

  ifelse water-store-max > 0 [
    set water-stress min list 1 (water-store / water-store-max)
  ] [
    set water-stress 0
  ]
end

; ----------------------------------------------------------------------------
; apply-water-storage-properties
; Leitet aus Boden- oder Objekttyp die Parameter des effektiven Wasserspeichers ab.
; ----------------------------------------------------------------------------
to apply-water-storage-properties  ;; patch context
if object-kind = "building" [
  if roof-style = "green-roof" [
    set-water-bucket 10.0 0.65 0.70
    stop
  ]
  set-water-bucket 0.05 0.01 0.00
  stop
]


  if object-kind = "tree" [
   set-water-bucket 30.0 1.00 0.80
    stop
  ]

  if object-kind = "hedge" [
    set-water-bucket 20.0 0.90 0.80
    stop
  ]

  if ground-kind = "Asphalt" [
    set-water-bucket 0.02 0.01 0.00
    stop
  ]

  if ground-kind = "Pflaster" [
    set-water-bucket 0.10 0.03 0.05
    stop
  ]

  if ground-kind = "Offenpflaster" [
    set-water-bucket 2.5 0.20 0.20
    stop
  ]

  if ground-kind = "Sand" [
    set-water-bucket 1.00 0.06 0.10
    stop
  ]

  if ground-kind = "Sportbelag" [
    set-water-bucket 0.02 0.01 0.00
    stop
  ]

  if ground-kind = "Rasen" [
    set-water-bucket 24.0 0.80 0.70
    stop
  ]

  set-water-bucket 0 0 0
end

; ----------------------------------------------------------------------------
; update-Oberfläche-label
; Schreibt aus der internen Semantik eine lesbare Oberflächenbezeichnung für Anzeige- und Legacy-Zwecke.
; ----------------------------------------------------------------------------
to update-Oberfläche-label  ;; patch context
  if object-kind = "building" [ set Oberfläche "Gebaeude" stop ]
  if object-kind = "tree" [ set Oberfläche "Baum" stop ]
  if object-kind = "hedge" [ set Oberfläche "Hecke" stop ]
  set Oberfläche ground-kind
end

; ----------------------------------------------------------------------------
; apply-roof-style
; Setzt den Dachstil eines Gebäude-Patches und synchronisiert die daraus folgenden Materialeigenschaften.
; ----------------------------------------------------------------------------
to apply-roof-style [style]  ;; patch context
  if object-kind != "building" [ stop ]
  if not member? style ["normal-roof" "green-roof"] [ stop ]
  set roof-style style
  sync-patch-semantics
end

; ----------------------------------------------------------------------------
; apply-wall-style
; Setzt den Wandstil eines Gebäude-Patches.
; ----------------------------------------------------------------------------
to apply-wall-style [style]  ;; patch context
  if object-kind != "building" [ stop ]
  if not member? style ["normal-wall" "green-wall"] [ stop ]
  set wall-style style
end

; ----------------------------------------------------------------------------
; wall-albedo-of
; Reporter für die Albedo eines Wandstils.
; ----------------------------------------------------------------------------
to-report wall-albedo-of [style]
  if style = "green-wall" [ report 0.25 ]
  if style = "normal-wall" [ report 0.35 ]
  report 0.35
end

; ----------------------------------------------------------------------------
; wall-green-of
; Reporter für den Begrünungsanteil eines Wandstils.
; ----------------------------------------------------------------------------
to-report wall-green-of [style]
  if style = "green-wall" [ report 1 ]
  report 0
end


; -----------------------------------------------------------------------------
; Abgeleitete Felder
; -----------------------------------------------------------------------------

; ============================================================================
; Abgeleitete räumliche Felder und Belastungslogik
; ----------------------------------------------------------------------------
; Hier werden Kontextgrößen wie Vegetationseinfluss, Wandexposition, räumliche Einfassung und der vereinfachte Komfortindex berechnet.
; ============================================================================

; ----------------------------------------------------------------------------
; rebuild-derived-fields
; Berechnet alle räumlichen Kontextfelder neu, die aus der Umgebung der Patches abgeleitet werden.
; ----------------------------------------------------------------------------
to rebuild-derived-fields
  compute-vegetation-influence
  compute-wall-context
  compute-enclosedness
end

; ----------------------------------------------------------------------------
; compute-comfort-index
; Berechnet einen vereinfachten thermischen Belastungsindex auf Patch-Ebene.
; ----------------------------------------------------------------------------
to-report compute-comfort-index  ;; patch context
  ;; Aufenthaltsnahe Belastung:
  ;; lokale Luft + direkte Sonne + langwellige Belastung heißer Flächen/Wände
  ;; minus Wind und Vegetation.
  ;; Wichtig: Vegetation entlastet stark, aber nicht bis zur Nullbelastung
  ;; an Extremtagen.

  let direct-sun solar-factor * (1 - shadow-level)

  let axial-neigh neighbors4
  let diagonal-neigh neighbors with [pxcor != [pxcor] of myself and pycor != [pycor] of myself]

  let axial-surface-mean ifelse-value any? axial-neigh
    [ mean [surface-temp] of axial-neigh ]
    [ surface-temp ]

  let diagonal-surface-mean ifelse-value any? diagonal-neigh
    [ mean [surface-temp] of diagonal-neigh ]
    [ surface-temp ]

  let surface-excess max list 0 (surface-temp - air-temp-local)
  let axial-excess max list 0 (axial-surface-mean - air-temp-local)
  let diagonal-excess max list 0 (diagonal-surface-mean - air-temp-local)

  let wall-height-factor min list 1.2 (wall-height-local / 8)

  let sw-eq 7.0 * direct-sun
  if member? object-kind ["tree" "hedge"] [
    set sw-eq 0.65 * sw-eq
  ]

  let lw-eq
    (0.38 * surface-excess) +
    (0.22 * axial-excess) +
    (0.10 * diagonal-excess) +
    (2.8 * wall-exposure * solar-factor * wall-height-factor * (1 - 0.80 * wall-green-local))

let humidity-load 0.03 * max list 0 (relative-humidity - 55)

let wind-relief 0.9 * sqrt (max list 0.5 Windgeschwindigkeit)
set wind-relief wind-relief * (1 - (0.20 * enclosedness))

let vegetation-relief 0.35 * veg-nearby

;; aktive Entlastung durch evapotranspirierende Fassadenbegrünung
;; wirkt nur dort, wo Fassadenkontakt bzw. Fassadennähe vorhanden ist
let ea-wall ((relative-humidity / 100) * saturation-vapor-pressure-kpa air-temp-local)
let es-wall saturation-vapor-pressure-kpa air-temp-local
let vpd-wall max list 0 (es-wall - ea-wall)
let wall-et-factor min list 1 (vpd-wall / 1.6)

let wall-evap-relief
  3.2 * wall-exposure * wall-green-local * solar-factor * (0.35 + (0.65 * wall-et-factor))

set shortwave-human sw-eq
set longwave-human lw-eq
set exposure-temp air-temp-local + sw-eq + lw-eq + humidity-load - wind-relief - vegetation-relief - wall-evap-relief

  report exposure-temp
end

; ----------------------------------------------------------------------------
; compute-vegetation-influence
; Berechnet, wie stark Vegetation in der näheren Umgebung eines Patches wirkt.
; ----------------------------------------------------------------------------
to compute-vegetation-influence
  ask patches [
    let trees-near-1 count patches in-radius 1.5 with [object-kind = "tree"]
    let trees-near-3 count patches in-radius 3.5 with [object-kind = "tree"]
    let hedges-near-1 count patches in-radius 1.5 with [object-kind = "hedge"]
    let hedges-near-3 count patches in-radius 3.5 with [object-kind = "hedge"]

    let tree-influence (0.55 * trees-near-1) + (0.18 * trees-near-3)
    let hedge-influence (0.35 * hedges-near-1) + (0.12 * hedges-near-3)

    set veg-nearby min list 1 ((tree-influence + hedge-influence) / 2.2)
    set tree-nearby veg-nearby
  ]
end

; ----------------------------------------------------------------------------
; compute-wall-context
; Ermittelt Wandexposition, Wandhöhe, Wandalbedo und Begrünung benachbarter Gebäude.
; ----------------------------------------------------------------------------
to compute-wall-context
  ask patches [
    set wall-exposure 0
    set wall-height-local 0
    set wall-albedo-local 0.35
    set wall-green-local 0
if object-kind != "building" [
  ;; Direkte Fassadenwirkung: nur unmittelbar angrenzende Gebäude
  let adj-buildings neighbors4 with [object-kind = "building"]

  ;; Abgeschwächte Nahbereichswirkung: Gebäudekanten bis Radius 2
  let near-buildings patches in-radius 2 with [
    object-kind = "building" and building-edge?
  ]

  if any? adj-buildings [
    set wall-exposure min list 1 ((count adj-buildings) / 2)
    set wall-height-local max [building-height] of adj-buildings
    set wall-albedo-local mean [ wall-albedo-of wall-style ] of adj-buildings
    set wall-green-local mean [ wall-green-of wall-style ] of adj-buildings
  ]

  if not any? adj-buildings and any? near-buildings [
    set wall-exposure 0.35
    set wall-height-local max [building-height] of near-buildings
    set wall-albedo-local mean [ wall-albedo-of wall-style ] of near-buildings
    set wall-green-local 0.55 * mean [ wall-green-of wall-style ] of near-buildings
  ]
]
  ]
end

; ----------------------------------------------------------------------------
; compute-enclosedness
; Schätzt, wie stark ein Ort durch Gebäude und Hecken räumlich eingefasst ist.
; ----------------------------------------------------------------------------
to compute-enclosedness
  ask patches [
    let total count patches in-radius 3
    let built count patches in-radius 3 with [object-kind = "building"]
    let hedge count patches in-radius 3 with [object-kind = "hedge"]
    ifelse total > 0 [
      set enclosedness min list 1 ((built + (0.35 * hedge)) / total)
    ] [
      set enclosedness 0
    ]
  ]
end


; -----------------------------------------------------------------------------
; Sonnenstand / Tagesgang
; -----------------------------------------------------------------------------

; ============================================================================
; Sonnenstand, Schatten und thermische Modellierung
; ----------------------------------------------------------------------------
; Dieser Block enthält die physikalische Kernlogik des Modells: Tagesgang, Sonnenstand, Schattenwurf, Spin-up und die zeitliche Entwicklung von Oberflächen- und Lufttemperatur sowie Wasserzuständen.
; ============================================================================

; ----------------------------------------------------------------------------
; update-solar-geometry
; Berechnet Tagesgang, Sonnenhöhe, Sonnenazimut, Solar-Faktor und die großräumige Hintergrundlufttemperatur.
; ----------------------------------------------------------------------------
to update-solar-geometry
  let daylight 14
  let max-elev 60
  let mean-air 25
  let amp-air 7
  let tmax-hour 16

  if Jahreszeit = "Frühling/Herbst" [
    set daylight 11
    set max-elev 45
    set mean-air 16
    set amp-air 7
    set tmax-hour 15
  ]

  if Jahreszeit = "Winter" [
    set daylight 8
    set max-elev 22
    set mean-air 5
    set amp-air 5
    set tmax-hour 14
  ]

  let sunrise 12 - (daylight / 2)
  let sunset 12 + (daylight / 2)

  ifelse (Stunde < sunrise) or (Stunde > sunset) [
    set solar-factor 0
    set sun-elevation 0
    set sun-azimuth 180
  ] [
    let daypos (Stunde - sunrise) / daylight
    set solar-factor max list 0 (sin (180 * daypos))
    set sun-elevation max-elev * solar-factor
    set sun-azimuth 90 + (180 * daypos)
  ]

  ;; leicht asymmetrischer Tagesgang, damit Vormittag nicht zu linear und der Nachmittagsabfall nicht spiegelbildlich verläuft
  let phase (360 * ((Stunde - tmax-hour) / 24))
  let base-shape (0.82 * cos phase) + (0.18 * cos ((2 * phase) - 35))
  set air-temp mean-air + (amp-air * base-shape)

  let mean-rh 58
  let amp-rh 16
  if Jahreszeit = "Frühling/Herbst" [
    set mean-rh 68
    set amp-rh 14
  ]
  if Jahreszeit = "Winter" [
    set mean-rh 78
    set amp-rh 10
  ]
  set relative-humidity (max list 25 (min list 95 (mean-rh + (amp-rh * cos (360 * ((Stunde - 5) / 24))))))
end


; -----------------------------------------------------------------------------
; Schatten
; -----------------------------------------------------------------------------

; ----------------------------------------------------------------------------
; cast-shadows
; Setzt alle Schattenwerte neu, ausgehend von Gebäuden und Vegetation.
; ----------------------------------------------------------------------------
to cast-shadows
  ask patches [ set shadow-level 0 ]

  if sun-elevation <= 0 [ stop ]

  ask patches with [building-edge?] [
    let d-x round (-1 * sin sun-azimuth)
    let d-y round (-1 * cos sun-azimuth)

    if (d-x != 0) or (d-y != 0) [
      let downstream patch-at d-x d-y
      if downstream = nobody or [object-kind] of downstream != "building" [
        cast-building-shadow
      ]
    ]
  ]

  ask patches with [member? object-kind ["tree" "hedge"]] [
    cast-vegetation-shadow
  ]
end

; ----------------------------------------------------------------------------
; cast-building-shadow
; Wirft vom Gebäuderand aus einen gerichteten Schatten in Sonnengegenrichtung.
; ----------------------------------------------------------------------------
to cast-building-shadow  ;; patch context
  let source-height building-height
  let strength 0.96
  let shadow-length round (1.00 * source-height / max list 0.18 (tan sun-elevation))
  let d-x (-1 * sin sun-azimuth)
  let d-y (-1 * cos sun-azimuth)

  let step 1
  while [step <= shadow-length] [
    let tx round (pxcor + d-x * step)
    let ty round (pycor + d-y * step)
    let target patch tx ty

    if target != nobody [
      if [object-kind] of target != "building" [
        ask target [
          set shadow-level max list shadow-level strength
        ]
      ]
    ]
    set step step + 1
  ]
end

; ----------------------------------------------------------------------------
; cast-vegetation-shadow
; Modelliert Schattenwurf von Bäumen und Hecken mit breiterem, weicherem Kronen- bzw. Vegetationsschatten.
; ----------------------------------------------------------------------------
to cast-vegetation-shadow  ;; patch context
  let source-height veg-height
  let shadow-length round (1.15 * source-height / max list 0.18 (tan sun-elevation))
  let d-x (-1 * sin sun-azimuth)
  let d-y (-1 * cos sun-azimuth)
  let canopy-radius max list 1 round (source-height / 4)
  let canopy-strength 0.72
  let tail-decay 0.035

  if object-kind = "hedge" [
    set shadow-length round (0.75 * source-height / max list 0.18 (tan sun-elevation))
    set canopy-radius max list 1 round (source-height / 2)
    set canopy-strength 0.58
    set tail-decay 0.055
  ]

  ask patches in-radius canopy-radius [
    set shadow-level max list shadow-level canopy-strength
  ]

  let step 1
  while [step <= shadow-length] [
    let tx round (pxcor + d-x * step)
    let ty round (pycor + d-y * step)
    let target patch tx ty
    if target != nobody [
      ask patches with [distance target <= canopy-radius] [
        let local-strength max list 0.18 (canopy-strength - (tail-decay * step))
        set shadow-level max list shadow-level local-strength
      ]
    ]
    set step step + 1
  ]
end


; -----------------------------------------------------------------------------
; Thermik
; -----------------------------------------------------------------------------

; ----------------------------------------------------------------------------
; spin-up-local-meteo
; Führt einen kurzen Vorlauf der lokalen Meteorologie durch, damit das Modell nicht mit unphysikalischen Startzuständen beginnt.
; ----------------------------------------------------------------------------
to spin-up-local-meteo [n-days]
  synchronisiere-zeitschritt
  let target-time simulationszeit
  let total-hours (24 * n-days)
  let done-hours 0
  let run-time zyklische-stunde (target-time - total-hours)

  while [done-hours < total-hours - zeit-epsilon] [
    let dt min list interner-zeitschritt-stunden (total-hours - done-hours)

    set-model-time run-time
    rebuild-derived-fields
    update-solar-geometry
    cast-shadows
    update-thermal-state dt

    set done-hours done-hours + dt
    set run-time zyklische-stunde (run-time + dt)
  ]

  set-model-time target-time
  rebuild-derived-fields
  update-solar-geometry
  cast-shadows
end



; -----------------------------------------------------------------------------
; Interaktive Bearbeitung
; -----------------------------------------------------------------------------

; ----------------------------------------------------------------------------
; update-thermal-state
; Berechnet die zeitliche Entwicklung von Oberflächentemperatur, lokaler Lufttemperatur, Wasserzustand und kumulierten Belastungsgrößen.
; ----------------------------------------------------------------------------
to update-thermal-state [dt-hours]
  let dt-seconds max list 60 (dt-hours * 3600)

  let sigma 5.67e-8
  let rho-air 1.20
  let cp-air 1005
  let lv 2.45e6

  let shortwave-max 850
  let deep-temp 24

  if Jahreszeit = "Frühling/Herbst" [
    set shortwave-max 680
    set deep-temp 15
  ]

  if Jahreszeit = "Winter" [
    set shortwave-max 320
    set deep-temp 4
  ]

  ;; --------------------------------------------------------------------------
  ;; 1) OBERFLÄCHEN- UND SUBSTRAT-UPDATE
  ;;
  ;; Hier wird die Oberflächentemperatur aus einer einfachen Energiebilanz
  ;; berechnet:
  ;;
  ;;   absorbierte kurzwellige Strahlung
  ;; + zusätzliche Wandstrahlung
  ;; + langwellige Bilanz
  ;; - fühlbarer Wärmefluss an die bodennahe Luft
  ;; - latenter Wärmefluss durch Verdunstung
  ;; - Wärmeleitung in den Untergrund
  ;;
  ;; Wichtig:
  ;; Die Materialparameter aus apply-ground-properties und
  ;; apply-effective-roof-properties sind nur Eingangsgrößen.
  ;; Die tatsächliche Dynamik entsteht hier über:
  ;;   surface-heat-capacity
  ;;   substrate-conductance
  ;;   max-surface-warming-rate
  ;;   max-surface-cooling-rate
  ;; --------------------------------------------------------------------------
  ask patches [
    let diffuse-share 0.18
    let solar-on-patch solar-factor * (diffuse-share + ((1 - diffuse-share) * (1 - shadow-level)))

    if solar-factor <= 0 [
      set solar-on-patch 0
    ]

    let absorbed-shortwave shortwave-max * solar-on-patch * (1 - albedo)

    ;; Wandnahe zusätzliche kurzwellige Belastung.
    ;; Grüne Wände reduzieren diese Zusatzbelastung deutlich.
    let wall-height-factor min list 1.2 (wall-height-local / 8)

    let wall-shortwave
      38 * wall-exposure *
      solar-factor *
      wall-height-factor *
      (1 - wall-albedo-local) *
      (1 - 0.75 * wall-green-local)

    ;; Für Nicht-Gebäudepatches wird die direkte Wand-Aufheizung reduziert,
    ;; weil die Wand nicht die gesamte Patchfläche selbst ist, sondern eine
    ;; angrenzende Strahlungsquelle.
    if object-kind != "building" [
      set wall-shortwave 0.65 * wall-shortwave
    ]

    ;; Vereinfachte langwellige Bilanz gegen einen effektiven Himmel.
    ;; Bei hoher Sonneneinstrahlung ist der effektive Himmel weniger stark
    ;; "kalt", nachts stärker.
    let sky-offset (18 - (10 * solar-factor))
    let sky-temp-k (air-temp + 273.15 - sky-offset)
    let surface-temp-k (surface-temp + 273.15)

    let net-longwave emissivity * sigma * ((sky-temp-k ^ 4) - (surface-temp-k ^ 4))

    ;; Aerodynamischer Austausch Oberfläche <-> lokale Luft.
    ;; Enge, eingefasste Bereiche sind schwächer durchlüftet.
    let g-h (0.0020 + (0.0015 * sqrt (Windgeschwindigkeit + 0.2)))
    set g-h g-h / (1 + (0.55 * enclosedness))

    ;; Vegetation koppelt die Oberfläche etwas schwächer direkt an die Luft,
    ;; weil Blätter/Kronen nicht wie eine massive heiße Bodenplatte wirken.
    if member? object-kind ["tree" "hedge"] [
      set g-h 0.70 * g-h
    ]

    ;; Rasen wird etwas schwächer direkt an die Luft gekoppelt als harte
    ;; mineralische Oberflächen.
    if ground-kind = "Rasen" and object-kind = "none" [
      set g-h 0.85 * g-h
    ]

    if object-kind = "building" [
      set g-h 1.00 * g-h
    ]

    let sensible-flux rho-air * cp-air * g-h * (surface-temp - air-temp-local)

    ;; ------------------------------------------------------------------------
    ;; Effektive Oberflächenwärmekapazität [J m-2 K-1]
    ;;
    ;; Niedriger Wert:
    ;;   Oberfläche reagiert schnell, heizt schnell auf und kühlt schnell ab.
    ;;
    ;; Hoher Wert:
    ;;   Oberfläche reagiert träge, niedrigere Spitzen, längerer Nachlauf.
    ;;
    ;; Asphalt:
    ;;   explizit niedriger als vorher, damit er schneller heiß wird.
    ;;
    ;; Rasen:
    ;;   reduziert von 520000 auf 440000, damit er abends nicht zu lange warm
    ;;   bleibt. Er bleibt trotzdem gepuffert.
    ;;
    ;; Baum/Hecke:
    ;;   weiterhin träge, weil Kronen/Vegetationsvolumen und Wasserpuffer
    ;;   keine harte heiße Platte darstellen.
    ;;
    ;; Gründach:
    ;;   bleibt gepuffert, aber die eigentliche Kühlung kommt wasserabhängig
    ;;   über latent-flux.
    ;; ------------------------------------------------------------------------
    let surface-heat-capacity (180000 + (380000 * thermal-mass))



if ground-kind = "Asphalt" and object-kind = "none" [
  set surface-heat-capacity 340000
]

if ground-kind = "Pflaster" and object-kind = "none" [
  set surface-heat-capacity 360000
]

if ground-kind = "Rasen" and object-kind = "none" [
  set surface-heat-capacity 300000
]
    if member? object-kind ["tree" "hedge"] [
      set surface-heat-capacity 480000
    ]

    if object-kind = "building" and roof-style = "green-roof" [
      set surface-heat-capacity 360000
    ]

    ;; ------------------------------------------------------------------------
    ;; Substratkopplung
    ;;
    ;; substrate-conductance steuert, wie stark Oberflächenwärme in den
    ;; darunterliegenden Speicher abgeführt wird.
    ;;
    ;; Asphalt:
    ;;   5.0 statt des aus thermal-mass abgeleiteten höheren Werts.
    ;;   Sonst verschwindet zu viel Energie im Untergrund und Asphalt bleibt
    ;;   oberflächlich zu kühl.
    ;;
    ;; Rasen:
    ;;   7.0 statt 9.0. Dadurch bleibt Rasen gepuffert, gibt aber abends
    ;;   weniger stark gespeicherte Wärme zurück.
    ;; ------------------------------------------------------------------------
    let substrate-heat-capacity (420000 + (620000 * thermal-mass))
    let substrate-conductance (4 + (6 * thermal-mass))




if ground-kind = "Asphalt" and object-kind = "none" [
  set substrate-conductance 5.0
]

if ground-kind = "Pflaster" and object-kind = "none" [
  set substrate-conductance 5.4
]

if ground-kind = "Rasen" and object-kind = "none" [
  set substrate-conductance 3.8
]
    if member? object-kind ["tree" "hedge"] [
      set substrate-conductance 8.5
    ]

    if object-kind = "building" and roof-style = "green-roof" [
      set substrate-conductance 5.2
    ]

    let ground-flux substrate-conductance * (surface-temp - substrate-temp)

    let substrate-relax
      substrate-heat-capacity *
      (deep-temp - substrate-temp) /
      ((30 + (52 * thermal-mass)) * 3600)

    ;; ------------------------------------------------------------------------
    ;; Wasserverfügbarkeit für Verdunstung
    ;;
    ;; water-availability ist 0..1.
    ;; Unter 5 % relativer Speicherfüllung wird praktisch keine Verdunstung
    ;; angenommen. Ab etwa 85 % Speicherfüllung ist Verdunstung nicht mehr
    ;; wasserlimitiert.
    ;; ------------------------------------------------------------------------
    let water-availability 0

    if water-store-max > 0 [
      let rel-water water-store / water-store-max
      set water-availability max list 0 (min list 1 ((rel-water - 0.05) / 0.80))
    ]

    let ea-air ((relative-humidity / 100) * (saturation-vapor-pressure-kpa air-temp-local))
    let es-surface (saturation-vapor-pressure-kpa surface-temp)
    let vpd-surface max list 0 (es-surface - ea-air)

    let available-radiative-energy max list 0 (absorbed-shortwave + wall-shortwave + net-longwave)

    ;; Potenzielle Verdunstungsleistung.
    ;; Die Faktoren sind didaktische Effektivwerte, keine exakte Penman-
    ;; Monteith-Bilanz.
    let aerodynamic-evap
      ((22 + (52 * sqrt (Windgeschwindigkeit + 0.2))) *
       evap-factor *
       wetness-factor *
       (0.30 + (0.70 * min list 1 (vpd-surface / 1.6))))

    ;; Rasen verdunstet stark, aber nur, wenn Wasser vorhanden ist.
    if ground-kind = "Rasen" and object-kind = "none" [
      set aerodynamic-evap 1.95 * aerodynamic-evap
    ]

    ;; Bäume und Hecken verdunsten stark, aber wurden gegenüber früher
    ;; über evap-factor und Wasserspeicher bereits entschärft.
    if member? object-kind ["tree" "hedge"] [
      set aerodynamic-evap 1.25 * aerodynamic-evap
    ]

    ;; Gründach bekommt zusätzliche Verdunstungseffizienz, bleibt aber
    ;; wasserlimitiert.
    if object-kind = "building" and roof-style = "green-roof" [
      set aerodynamic-evap 1.05 * aerodynamic-evap
    ]

    ;; Latenter Fluss darf nicht mehr als 92 % der verfügbaren Strahlungsenergie
    ;; verbrauchen.
    let potential-latent-flux min list (0.92 * available-radiative-energy) aerodynamic-evap

    ;; Nachts bzw. fast ohne Sonne wird Verdunstung stark reduziert.
    if solar-factor < 0.05 [
      set potential-latent-flux 0.35 * potential-latent-flux
    ]

    ;; Wasserlimit: Es kann nur so viel verdunsten, wie im Speicher vorhanden ist.
    let water-limited-flux (water-store * lv) / dt-seconds
    let latent-flux min list (potential-latent-flux * water-availability) water-limited-flux

    let evap-mm (latent-flux * dt-seconds) / lv

    let recharge-space max list 0 (water-store-max - water-store)
    let recharge-mm min list recharge-space ((Niederschlag-mm-pro-stunde + groundwater-recharge-mm-pro-stunde) * dt-hours)

    set water-store max list 0 (min list water-store-max (water-store - evap-mm + recharge-mm))
    set water-stress water-availability

    ;; ------------------------------------------------------------------------
    ;; Oberflächentemperaturänderung
    ;;
    ;; net-surface-flux ist die effektive Energiebilanz der Oberfläche.
    ;; dts ist daraus die Temperaturänderung.
    ;;
    ;; Wichtig:
    ;; Die Kappung ist jetzt asymmetrisch:
    ;;   max-surface-warming-rate  = maximale Erwärmung pro Stunde
    ;;   max-surface-cooling-rate  = maximale Abkühlung pro Stunde
    ;;
    ;; Damit kann Rasen langsam warm werden, aber abends trotzdem plausibel
    ;; schneller abkühlen. Asphalt und Bitumendach dürfen schneller reagieren.
    ;; ------------------------------------------------------------------------
    let net-surface-flux absorbed-shortwave + wall-shortwave + net-longwave - sensible-flux - latent-flux - ground-flux

    let dts (net-surface-flux * dt-seconds) / surface-heat-capacity

    let max-warm-rate max-surface-warming-rate
    let max-cool-rate max-surface-cooling-rate

    if dts > (max-warm-rate * dt-hours) [
      set dts (max-warm-rate * dt-hours)
    ]

    if dts < (-1 * max-cool-rate * dt-hours) [
      set dts (-1 * max-cool-rate * dt-hours)
    ]

    set surface-temp surface-temp + dts

    ;; Substrattemperatur wird ebenfalls stabilisiert, aber bewusst einfacher.
    let dtsub ((ground-flux + substrate-relax) * dt-seconds) / substrate-heat-capacity

    if dtsub > (1.0 * dt-hours) [
      set dtsub (1.0 * dt-hours)
    ]

    if dtsub < (-1.0 * dt-hours) [
      set dtsub (-1.0 * dt-hours)
    ]

    set substrate-temp substrate-temp + dtsub
  ]

  ;; --------------------------------------------------------------------------
  ;; 2) BODENNAHES LUFTFELD
  ;;
  ;; Die lokale Lufttemperatur wird nicht direkt auf die Oberflächentemperatur
  ;; gesetzt. Sie reagiert über:
  ;;
  ;;   dta-surface     = Kopplung an lokalen Oberflächen-Footprint
  ;;   dta-lateral     = horizontale Mischung mit Nachbarpatches
  ;;   dta-background  = vertikaler Austausch mit Hintergrundluft
  ;;   dta-wall        = zusätzliche Fassadenwärmelast
  ;;   dta-wall-cooling = aktive ET-Kühlung grüner Fassaden
  ;;
  ;; Der wichtige Bugfix:
  ;; dta-wall-cooling wurde vorher berechnet, aber nicht zu dta addiert.
  ;; Dadurch hatte die neue Fassaden-ET keine Wirkung auf die Lufttemperatur.
  ;; --------------------------------------------------------------------------
  ask patches [
    let axial-neigh neighbors4
    let diagonal-neigh neighbors with [
      pxcor != [pxcor] of myself and
      pycor != [pycor] of myself
    ]

    let axial-surface-mean ifelse-value any? axial-neigh
      [ mean [surface-temp] of axial-neigh ]
      [ surface-temp ]

    let diagonal-surface-mean ifelse-value any? diagonal-neigh
      [ mean [surface-temp] of diagonal-neigh ]
      [ surface-temp ]

    ;; Lokaler Oberflächen-Footprint.
    ;; Eigenes Patch zählt am stärksten, direkte Nachbarn mittel, diagonale
    ;; Nachbarn schwach.
    let footprint-surface-temp
      ((3.2 * surface-temp) +
       (0.9 * axial-surface-mean) +
       (0.3 * diagonal-surface-mean)) / 4.4

    let laplace-air 0

    if any? axial-neigh [
      set laplace-air laplace-air +
        (sum [air-temp-local] of axial-neigh - (count axial-neigh * air-temp-local))
    ]

    if any? diagonal-neigh [
      set laplace-air laplace-air +
        0.5 * (sum [air-temp-local] of diagonal-neigh - (count diagonal-neigh * air-temp-local))
    ]

    ;; Oberfläche-Luft-Kopplung.
    ;; Gegenüber der alten Version leicht erhöht, damit die Luft nicht massiv
    ;; hinter den inzwischen plausiblen Oberflächentemperaturen zurückbleibt.
    let surface-coupling (0.095 + (0.030 * sqrt (Windgeschwindigkeit + 0.2)))
    set surface-coupling surface-coupling / (1 + (0.40 * enclosedness))

    if member? object-kind ["tree" "hedge"] [
      set surface-coupling 0.90 * surface-coupling
    ]

    if object-kind = "building" [
      set surface-coupling 0.85 * surface-coupling
    ]

    ;; Horizontale Mischung zwischen Nachbarpatches.
    let lateral-mix (0.010 + (0.006 * Windgeschwindigkeit))
    set lateral-mix lateral-mix / (1 + (0.30 * enclosedness))

    ;; Vertikale Mischung gegen Hintergrundluft.
    ;; Bei Sonne und Wind stärker, in eingefassten Bereichen schwächer.
    let vertical-mix (0.015 + (0.015 * solar-factor) + (0.008 * sqrt (Windgeschwindigkeit + 0.2)))
    set vertical-mix vertical-mix / (1 + (0.45 * enclosedness))

    if member? object-kind ["tree" "hedge"] [
      set vertical-mix 0.85 * vertical-mix
    ]

    let wall-height-factor min list 1.2 (wall-height-local / 8)

    ;; Wärmelast durch Fassaden.
    ;; Grüne Fassaden reduzieren diesen Wärmeeintrag.
    let wall-air-load
      0.25 *
      wall-exposure *
      solar-factor *
      wall-height-factor *
      (1 - 0.60 * wall-green-local)

    ;; Aktive Luftkühlung durch evapotranspirierende Fassadenbegrünung.
    ;; Der Effekt steigt mit:
    ;;   Wandkontakt/Fassadennähe,
    ;;   Begrünungsanteil,
    ;;   Sonnenantrieb,
    ;;   Wandhöhe,
    ;;   Dampfdruckdefizit.
    let ea-wall-air ((relative-humidity / 100) * (saturation-vapor-pressure-kpa air-temp-local))
    let es-wall-air (saturation-vapor-pressure-kpa air-temp-local)
    let vpd-wall-air max list 0 (es-wall-air - ea-wall-air)
    let wall-et-air-factor min list 1 (vpd-wall-air / 1.6)

    let wall-air-cooling
      0.55 *
      wall-exposure *
      wall-green-local *
      solar-factor *
      wall-height-factor *
      (0.35 + (0.65 * wall-et-air-factor))

;; direkte lokale Luftkühlung durch evapotranspirierenden Rasen
;; wirkt nur bei Wasserverfügbarkeit, Sonne und trocken-warmer Luft
let grass-air-cooling 0

if ground-kind = "Rasen" and object-kind = "none" [
  let ea-grass-air ((relative-humidity / 100) * saturation-vapor-pressure-kpa air-temp-local)
  let es-grass-air saturation-vapor-pressure-kpa air-temp-local
  let vpd-grass-air max list 0 (es-grass-air - ea-grass-air)
  let grass-et-air-factor min list 1 (vpd-grass-air / 1.6)

  set grass-air-cooling
    0.70 *
    water-stress *
    solar-factor *
    (0.35 + (0.65 * grass-et-air-factor))
]

let dta-surface surface-coupling * (footprint-surface-temp - air-temp-local) * dt-hours
let dta-lateral lateral-mix * laplace-air * dt-hours
let dta-background vertical-mix * (air-temp - air-temp-local) * dt-hours
let dta-wall wall-air-load * dt-hours
let dta-wall-cooling (-1 * wall-air-cooling * dt-hours)
let dta-grass-cooling (-1 * grass-air-cooling * dt-hours)

let dta dta-surface + dta-lateral + dta-background + dta-wall + dta-wall-cooling + dta-grass-cooling


    ;; Materialabhängige Lufttemperatur-Kappung.
    ;; Harte, heiße Oberflächen dürfen die lokale Luft schneller erwärmen.
    ;; Vegetation und Gründächer bleiben stärker gedämpft.
    let max-air-rate max-air-dta-rate

    if dta > (max-air-rate * dt-hours) [
      set dta (max-air-rate * dt-hours)
    ]

    if dta < (-1 * max-air-rate * dt-hours) [
      set dta (-1 * max-air-rate * dt-hours)
    ]

    set air-temp-local-next air-temp-local + dta
  ]

  ;; --------------------------------------------------------------------------
  ;; 3) ZUSTÄNDE UND DOSISGRÖSSEN FORTSCHREIBEN
  ;;
  ;; Nach dem synchronen Luftupdate werden Maxima, Komfortindex und integrierte
  ;; Hitzelast während der Schulzeit aktualisiert.
  ;; --------------------------------------------------------------------------
  ask patches [
    let axial-neigh neighbors4
    let diagonal-neigh neighbors with [
      pxcor != [pxcor] of myself and
      pycor != [pycor] of myself
    ]

    let axial-surface-mean ifelse-value any? axial-neigh
      [ mean [surface-temp] of axial-neigh ]
      [ surface-temp ]

    let diagonal-surface-mean ifelse-value any? diagonal-neigh
      [ mean [surface-temp] of diagonal-neigh ]
      [ surface-temp ]

    ;; Wird aktuell nicht direkt verwendet, bleibt aber als möglicher Anschluss
    ;; für spätere Belastungslogik erhalten.
    let score-neighbour-temp ((1.3 * axial-surface-mean) + (0.7 * diagonal-surface-mean)) / 2

    set air-temp-local air-temp-local-next
    set comfort-index compute-comfort-index
    set exposure-temp comfort-index
    set temp-delta surface-temp - air-temp-local
    set heat-score-step patch-heat-step-score comfort-index

    set air-temp-local-max max list air-temp-local-max air-temp-local
    set surface-temp-max max list surface-temp-max surface-temp
    set comfort-index-max max list comfort-index-max comfort-index

    if in-schulzeit? [
      set heat-dose-air heat-dose-air + ((max list 0 (air-temp-local - 28)) * dt-hours)
      set heat-dose-surface heat-dose-surface + ((max list 0 (surface-temp - 36)) * dt-hours)
      set heat-dose-comfort heat-dose-comfort + (heat-score-step * dt-hours)
    ]

    ifelse water-store-max > 0 [
      set water-store-rel water-store / water-store-max
    ] [
      set water-store-rel 0
    ]

    set water-stress-true 1 - water-stress
  ]
end

to-report max-surface-warming-rate  ;; patch context
  ;; maximale Oberflächenerwärmung in °C pro Stunde
  ;;
  ;; Asphalt und Bitumendach dürfen schnell hochlaufen.
  ;; Rasen, Baum, Hecke und Gründach werden stärker gedämpft.

  if object-kind = "building" [
    if roof-style = "normal-roof" [ report 5.4 ]
    if roof-style = "green-roof"  [ report 3.6 ]
    report 4.0
  ]

  if object-kind = "tree"  [ report 2.2 ]
  if object-kind = "hedge" [ report 2.5 ]

  if ground-kind = "Asphalt"       [ report 5.0 ]
  if ground-kind = "Sportbelag"    [ report 4.6 ]
  if ground-kind = "Sand"          [ report 4.2 ]
  if ground-kind = "Pflaster"      [ report 3.4 ]
  if ground-kind = "Offenpflaster" [ report 3.1 ]
  if ground-kind = "Rasen"         [ report 2.5 ]

  report 3.8
end

to-report max-surface-cooling-rate  ;; patch context
  ;; maximale Oberflächenabkühlung in °C pro Stunde
  ;;
  ;; Rasen darf schneller abkühlen als er sich erwärmt.
  ;; Das verhindert den unplausiblen langen warmen Nachlauf.
  ;;
  ;; Sand darf stark abkühlen, weil geringe Wärmeträgheit.
  ;; Asphalt/Bitumen kühlen ebenfalls deutlich, aber nicht völlig abrupt.

  if object-kind = "building" [
    if roof-style = "normal-roof" [ report 4.2 ]
    if roof-style = "green-roof"  [ report 6.4 ]
    report 4.0
  ]

  if object-kind = "tree"  [ report 2.8 ]
  if object-kind = "hedge" [ report 3.0 ]

  if ground-kind = "Asphalt"       [ report 4.4 ]
  if ground-kind = "Sportbelag"    [ report 4.0 ]
  if ground-kind = "Sand"          [ report 4.6 ]
  if ground-kind = "Pflaster"      [ report 3.6 ]
  if ground-kind = "Offenpflaster" [ report 3.8 ]
  if ground-kind = "Rasen"         [ report 7.8 ]

  report 3.8
end
to-report max-air-dta-rate  ;; patch context
  ;; maximale Änderung der lokalen bodennahen Lufttemperatur in °C pro Stunde

  if object-kind = "building" [
    if roof-style = "normal-roof" [ report 2.4 ]
    if roof-style = "green-roof"  [ report 1.6 ]
    report 2.0
  ]

  if object-kind = "tree"  [ report 1.4 ]
  if object-kind = "hedge" [ report 1.5 ]

  if ground-kind = "Asphalt"       [ report 3.2 ]
  if ground-kind = "Sportbelag"    [ report 3.0 ]
  if ground-kind = "Sand"          [ report 2.6 ]
  if ground-kind = "Pflaster"      [ report 2.9 ]
  if ground-kind = "Offenpflaster" [ report 2.1 ]
  if ground-kind = "Rasen"         [ report 1.8 ]

  report 2.2
end
to-report schulbeginn-stunde
  report 7.0
end

to-report schulende-stunde
  report 16.0
end

to-report schulzeit-stunden
  report max list 0 (schulende-stunde - schulbeginn-stunde)
end

to-report belastungsstunden-schwelle
  ;; Legacy-Reporter. Die aktuelle Logik arbeitet direkt mit einem kontinuierlichen
  ;; Belastungsfaktor zwischen 0 und 1 und integriert ihn zu Belastungsstunden.
  report 0
end

to-report in-schulzeit?
  report (Stunde >= schulbeginn-stunde) and (Stunde < schulende-stunde)
end

to-report clamp01 [x]
  report max list 0 (min list 1 x)
end

to-report scale-between [x x0 x1]
  if x1 <= x0 [ report 0 ]
  report clamp01 ((x - x0) / (x1 - x0))
end

to-report patch-heat-step-score [idx]
  ;; kontinuierlicher Belastungsfaktor 0..1
  ;; kein harter Null-Kollaps unter Bäumen an Extremtagen

  if Jahreszeit = "Sommer" [
    if idx <= 24 [ report 0 ]
    if idx <= 29 [ report 0.08 + (0.17 * ((idx - 24) / 5)) ]
    if idx <= 38 [ report 0.25 + (0.75 * ((idx - 29) / 9)) ]
    report 1
  ]

  if Jahreszeit = "Frühling/Herbst" [
    if idx <= 18 [ report 0 ]
    if idx <= 23 [ report 0.08 + (0.17 * ((idx - 18) / 5)) ]
    if idx <= 31 [ report 0.25 + (0.75 * ((idx - 23) / 8)) ]
    report 1
  ]

  if idx <= 8 [ report 0 ]
  if idx <= 12 [ report 0.08 + (0.17 * ((idx - 8) / 4)) ]
  if idx <= 18 [ report 0.25 + (0.75 * ((idx - 12) / 6)) ]
  report 1
end


; ============================================================================
; Interaktive Bearbeitung und Messstationen
; ----------------------------------------------------------------------------
; Hier sind alle Funktionen gebündelt, die das direkte Bearbeiten der Karte und den Umgang mit Messstationen steuern.
; ============================================================================


to clear-selection
  ask patches [ set selected-area? false ]
  set selection-active? false
  set selection-start-patch nobody
  set selection-end-patch nobody

  set sel-count 0
  set sel-air-mean 0
  set sel-air-max 0
  set sel-surface-mean 0
  set sel-surface-max 0
  set sel-comfort-mean 0
  set sel-comfort-max 0
  set sel-heat-air-sum 0
  set sel-heat-surface-sum 0
  set sel-heat-comfort-sum 0
end

to update-rect-selection [p1 p2]
  if p1 = nobody or p2 = nobody [ stop ]

  let x1 min list [pxcor] of p1 [pxcor] of p2
  let x2 max list [pxcor] of p1 [pxcor] of p2
  let y1 min list [pycor] of p1 [pycor] of p2
  let y2 max list [pycor] of p1 [pycor] of p2

  ask patches [ set selected-area? false ]
  ask patches with [
    pxcor >= x1 and pxcor <= x2 and
    pycor >= y1 and pycor <= y2
  ] [
    set selected-area? true
  ]
end

to update-selection-stats
  let sel patches with [selected-area?]

  if not any? sel [
    set sel-count 0
    set sel-air-mean 0
    set sel-air-max 0
    set sel-surface-mean 0
    set sel-surface-max 0
    set sel-comfort-mean 0
    set sel-comfort-max 0
    set sel-heat-air-sum 0
    set sel-heat-surface-sum 0
    set sel-heat-comfort-sum 0
    stop
  ]

  set sel-count count sel

  set sel-air-mean mean [air-temp-local] of sel
  set sel-air-max max [air-temp-local] of sel

  set sel-surface-mean mean [surface-temp] of sel
  set sel-surface-max max [surface-temp] of sel

  set sel-comfort-mean mean [comfort-index] of sel
  set sel-comfort-max max [comfort-index] of sel

  ;; Für Flächenvergleiche werden Mittelwerte verwendet, damit große Auswahlen
  ;; nicht automatisch höhere Belastungen anzeigen als kleine Auswahlen.
  set sel-heat-air-sum mean [heat-dose-air] of sel
  set sel-heat-surface-sum mean [heat-dose-surface] of sel
  set sel-heat-comfort-sum mean [heat-dose-comfort] of sel
end


to handle-area-selection
  ;; Absicherung: Nach clear-all oder alten Modellständen kann mouse-was-down?
  ;; numerisch 0 sein. Für AND-Abfragen muss es aber TRUE/FALSE sein.
  if not is-boolean? mouse-was-down? [
    set mouse-was-down? false
  ]

  if not is-boolean? selection-active? [
    set selection-active? false
  ]

  if mouse-inside? and mouse-down? [
    let target patch mouse-xcor mouse-ycor

    if target != nobody [
      if not mouse-was-down? [
        set selection-start-patch target
        set selection-end-patch target
        set selection-active? true
      ]

      set selection-end-patch target
      update-rect-selection selection-start-patch selection-end-patch
      update-selection-stats
      recolor-world
      refresh-station-appearance
      display
    ]
  ]

  if selection-active? and mouse-was-down? and (not mouse-down?) [
    update-selection-stats
    set selection-active? false
  ]

  set mouse-was-down? mouse-down?
end

; ----------------------------------------------------------------------------
; handle-mouse-edit
; Steuert die Kartenbearbeitung per Maus und verteilt je nach gewähltem Element die Bearbeitungsaktion auf den Zielbereich.
; ----------------------------------------------------------------------------
to handle-mouse-edit
  ;; Gebietsauswahl muss zuerst abgefangen werden.
  ;; Sonst läuft sie in die normale Bearbeitungslogik hinein.
  if Element = "Gebiet-auswählen" [
    handle-area-selection
    stop
  ]

  if mouse-inside? and mouse-down? [
    let target patch mouse-xcor mouse-ycor

    if target != nobody [

      ;; Stationen nur einmal beim ersten Klick setzen/entfernen,
      ;; nicht dauerhaft beim Ziehen.
      if not mouse-was-down? [
        if Element = "Station-setzen" [
          Station-setzen target
          refresh-display
          set mouse-was-down? mouse-down?
          stop
        ]

        if Element = "Station-entfernen" [
          Station-entfernen target
          refresh-display
          set mouse-was-down? mouse-down?
          stop
        ]
      ]

      ;; Dachbearbeitung: alle Gebäudepatches im Pinselradius.
      if member? Element ["Dach" "Dach-grün"] [
        ask ([patches in-radius Pinselgrösse with [object-kind = "building"]] of target) [
          apply-Element
        ]
        refresh-display
        set mouse-was-down? mouse-down?
        stop
      ]

      ;; Wandbearbeitung: nur Fassaden-/Randpatches von Gebäuden.
      if member? Element ["Wand" "Wand-grün"] [
        ask ([patches in-radius Pinselgrösse with [building-edge?]] of target) [
          apply-Element
        ]
        refresh-display
        set mouse-was-down? mouse-down?
        stop
      ]

      ;; Normale Flächen- und Objektbearbeitung:
      ;; Asphalt, Pflaster, Offenpflaster, Sand, Sportbelag, Rasen,
      ;; Baum, Hecke, Gebäude, Loeschen.
      if member? Element [
        "Asphalt" "Pflaster" "Offenpflaster" "Sand" "Sportbelag" "Rasen"
        "Baum" "Hecke" "Gebäude" "Loeschen"
      ] [
        ask ([patches in-radius Pinselgrösse] of target) [
          apply-Element
        ]
        refresh-display
        set mouse-was-down? mouse-down?
        stop
      ]
    ]
  ]

  set mouse-was-down? mouse-down?
end

; ----------------------------------------------------------------------------
; apply-Element
; Wendet das aktuell gewählte Bearbeitungselement auf einen Patch an.
; ----------------------------------------------------------------------------
to apply-Element  ;; patch context
  if Element = "Asphalt"    [ set-ground-kind "Asphalt" set-object-kind "none" stop ]
  if Element = "Pflaster"   [ set-ground-kind "Pflaster" set-object-kind "none" stop ]
  if Element = "Offenpflaster"      [ set-ground-kind "Offenpflaster" set-object-kind "none" stop ]
  if Element = "Sand"       [ set-ground-kind "Sand" set-object-kind "none" stop ]
  if Element = "Sportbelag" [ set-ground-kind "Sportbelag" set-object-kind "none" stop ]
  if Element = "Rasen"      [ set-ground-kind "Rasen" set-object-kind "none" stop ]

  if Element = "Baum" [ set-object-kind "tree" stop ]
  if Element = "Hecke" [ set-object-kind "hedge" stop ]

  if Element = "Gebäude" [
    set-object-kind "building"
    set building-height Gebäudehöhe
    sync-patch-semantics
    stop
  ]

  if Element = "Loeschen" [
    set-ground-kind "Pflaster"
    set-object-kind "none"
    stop
  ]

  if Element = "Dach" [ apply-roof-style "normal-roof" stop ]
  if Element = "Dach-grün" [ apply-roof-style "green-roof" stop ]
  if Element = "Wand" [ apply-wall-style "normal-wall" stop ]
  if Element = "Wand-grün" [ apply-wall-style "green-wall" stop ]
end

; ----------------------------------------------------------------------------
; Station-setzen
; Erzeugt eine neue Messstation auf einem Zielpatch, sofern dort noch keine Station liegt und die maximale Stationszahl nicht erreicht ist.
; ----------------------------------------------------------------------------
to Station-setzen [target-patch]
  if any? stations with [patch-here = target-patch] [ stop ]
  if count stations >= max-stations [ stop ]

  create-stations 1 [
    move-to target-patch
    set station-id next-station-id
    set station-color station-color-of station-id
    set current-reading [air-temp-local] of patch-here
    set shape "station"
    set size 3.8
    set color station-color
    set hidden? false
    set label word "M" station-id
    set label-color blue
  ]

  set next-station-id next-station-id + 1
end

; ----------------------------------------------------------------------------
; Station-entfernen
; Entfernt eine Messstation auf dem Zielpatch.
; ----------------------------------------------------------------------------
to Station-entfernen [target-patch ]
  ask stations with [distance target-patch <= 3] [ die ]
end

; ----------------------------------------------------------------------------
; refresh-station-appearance
; Setzt Aussehen, Größe, Farbe und Label aller Messstationen konsistent neu.
; ----------------------------------------------------------------------------
to refresh-station-appearance
  ask stations [
    set shape "station"
    set size 3.8
    set color station-color
    set hidden? false
    set label word " M" station-id
    set label-color blue
  ]
end

; ----------------------------------------------------------------------------
; clear-stations
; Löscht alle Stationen und setzt die Stationsverwaltung zurück.
; ----------------------------------------------------------------------------
to clear-stations
  ask stations [ die ]
  set next-station-id 1
  update-station-readings
  setup-station-plot
end

; ----------------------------------------------------------------------------
; update-station-readings
; Aktualisiert die aktuellen Stationsmesswerte und daraus abgeleitete globale Kennzahlen.
; ----------------------------------------------------------------------------
to update-station-readings
  ask stations [
    set current-reading [air-temp-local] of patch-here
  ]

  ifelse any? stations [
    set mean-station-temp mean [current-reading] of stations
    set hottest-station-temp max [current-reading] of stations
    set coolest-station-temp min [current-reading] of stations
  ] [
    set mean-station-temp 0
    set hottest-station-temp 0
    set coolest-station-temp 0
  ]
end

; ============================================================================
; Plotaufbau und Plotaktualisierung
; ----------------------------------------------------------------------------
; Dieser Block definiert die Erzeugung und Fortschreibung des Temperaturdiagramms sowie die dazu nötigen Hilfsfunktionen für y-Achsen und Plot-Pens.
; ============================================================================

; ----------------------------------------------------------------------------
; setup-station-plot
; Bereitet das Stationsdiagramm mit passenden Pens und jahreszeitabhängiger y-Achse vor.
; ----------------------------------------------------------------------------
to setup-station-plot
  let ymin plot-common-ymin
  let ymax plot-common-ymax

  if Jahreszeit = "Winter" [
    set ymin -5
    set ymax 14
  ]
  if Jahreszeit = "Sommer" [
    set ymin 10
    set ymax 52
  ]
  if Jahreszeit = "Frühling/Herbst" [
    set ymin 2
    set ymax 32
  ]

  if ymax <= ymin [ set ymax ymin + 5 ]

  set-current-plot "Stationen Temperatur"
  clear-plot
  auto-plot-off
  set-plot-x-range 0 24
  set-plot-y-range ymin ymax

  create-temporary-plot-pen "T-Modellantrieb"
  set-plot-pen-color gray + 2
  set-plot-pen-mode 0

;  create-temporary-plot-pen "T-Luft 2m Mittelwert"
;  set-plot-pen-color magenta
;  set-plot-pen-mode 0
;
;  create-temporary-plot-pen "T-Oberfläche Mittelwert"
;  set-plot-pen-color black
;  set-plot-pen-mode 0
;
  let ordered-stations sort-by [[a b] -> [station-id] of a < [station-id] of b] stations
  foreach ordered-stations [ s ->
    create-temporary-plot-pen (word "M" [station-id] of s)
    set-plot-pen-color [station-color] of s
    set-plot-pen-mode 0

    create-temporary-plot-pen (word "Ts_" [station-id] of s)
    set-plot-pen-color [station-color] of s
    set-plot-pen-mode 2
  ]
end

; ----------------------------------------------------------------------------
; update-station-plot
; Schreibt aktuelle Temperaturwerte in das Stationsdiagramm.
; ----------------------------------------------------------------------------
to update-station-plot
  let x simulationszeit
  let ymin plot-common-ymin
  let ymax plot-common-ymax
  if ymax <= ymin [ set ymax ymin + 5 ]

  let ordered-stations sort-by [[a b] -> [station-id] of a < [station-id] of b] stations

  set-current-plot "Stationen Temperatur"
  auto-plot-off
  set-plot-x-range 0 24
  set-plot-y-range ymin ymax

  ensure-plot-pen "T-Modellantrieb" (gray + 2)
  set-plot-pen-mode 0
  plotxy x air-temp

;  ensure-plot-pen "T-Luft 2m Mittelwert" (gray - 1)
;  set-plot-pen-mode 0
;  plotxy x mean [air-temp-local] of patches
;
;  ensure-plot-pen "T-Oberfläche Mittelwert" black
;  set-plot-pen-mode 2
;  plotxy x mean [surface-temp] of patches

  foreach ordered-stations [ s ->
    let pen-air (word "M" [station-id] of s)
    ensure-plot-pen pen-air [station-color] of s
    set-plot-pen-mode 0
    plotxy x [current-reading] of s

    let pen-surface (word "Ts_" [station-id] of s)
    ensure-plot-pen pen-surface [station-color] of s
    set-plot-pen-mode 2
    plotxy x [surface-temp] of [patch-here] of s
  ]
end

; -----------------------------------------------------------------------------
; Kartenansicht
; -----------------------------------------------------------------------------

; ----------------------------------------------------------------------------
; ensure-plot-pen
; Stellt sicher, dass ein Plot-Pen existiert und die gewünschte Farbe hat.
; ----------------------------------------------------------------------------
to ensure-plot-pen [pen-name pen-color]
  if not plot-pen-exists? pen-name [
    create-temporary-plot-pen pen-name
  ]
  set-current-plot-pen pen-name
  set-plot-pen-color pen-color
end

; ----------------------------------------------------------------------------
; round-down-to
; Rundet einen Wert auf ein vorgegebenes Raster nach unten.
; ----------------------------------------------------------------------------
to-report round-down-to [step value]
  report step * floor (value / step)
end

; ----------------------------------------------------------------------------
; round-up-to
; Rundet einen Wert auf ein vorgegebenes Raster nach oben.
; ----------------------------------------------------------------------------
to-report round-up-to [step value]
  report step * ceiling (value / step)
end

; ----------------------------------------------------------------------------
; plot-common-ymin
; Ermittelt eine gemeinsame sinnvolle Untergrenze für Temperaturplots.
; ----------------------------------------------------------------------------
to-report plot-common-ymin
  let ymin min list tmin-luft oberflaeche-min-lauf
  if any? stations [
    set ymin min list ymin (min [current-reading] of stations)
    set ymin min list ymin (min [ [surface-temp] of patch-here ] of stations)
  ]
  report round-down-to 5 (ymin - 1)
end

; ----------------------------------------------------------------------------
; plot-common-ymax
; Ermittelt eine gemeinsame sinnvolle Obergrenze für Temperaturplots.
; ----------------------------------------------------------------------------
to-report plot-common-ymax
  let ymax max list tmax-luft oberflaeche-max-lauf
  if any? stations [
    set ymax max list ymax (max [current-reading] of stations)
    set ymax max list ymax (max [ [surface-temp] of patch-here ] of stations)
  ]
  report round-up-to 5 (ymax + 1)
end

; ============================================================================
; Indikatoren, Reporter und Protokollierung
; ----------------------------------------------------------------------------
; Hier werden globale Kennwerte aktualisiert und textbasierte Reporter für Monitore, Tabellen-Output und Protokolle bereitgestellt.
; ============================================================================

; ----------------------------------------------------------------------------
; update-indicators
; Aktualisiert globale Kennzahlen für Monitore und Diagrammskalierung.
; ----------------------------------------------------------------------------
to update-indicators
  set Oberflächen-Temp mean [surface-temp] of patches
  set hottest-temp max [surface-temp] of patches

  set oberflaeche-min-aktuell min [surface-temp] of patches
  set oberflaeche-max-aktuell max [surface-temp] of patches

  set oberflaeche-min-lauf min list oberflaeche-min-lauf oberflaeche-min-aktuell
  set oberflaeche-max-lauf max list oberflaeche-max-lauf oberflaeche-max-aktuell

  set tmin-luft min list tmin-luft (min [air-temp-local] of patches)
  set tmax-luft max list tmax-luft (max [air-temp-local] of patches)

  set shaded-share 100 * (count patches with [shadow-level > 0.5]) / count patches
  set tree-share 100 * (count patches with [object-kind = "tree"]) / count patches
  set cool-share 100 * (count patches with [object-kind = "building" and roof-style = "green-roof"]) / max list 1 (count patches with [object-kind = "building"])
end


; -----------------------------------------------------------------------------
; Komfortfunktionen für Buttons
; -----------------------------------------------------------------------------
to toggle-legende
  set Legende-an? not Legende-an?
  recolor-world
  refresh-station-appearance
  display
end

to toggle-sand
  let feld patches with [
    pxcor >= 5 and pxcor <= 13 and
    pycor >= -15 and pycor <= -1
  ]

  ifelse any? feld with [ground-kind != "Sand" or object-kind != "none"] [
    ask feld [
      set-ground-kind "Sand"
      set-object-kind "none"
    ]
  ] [
    ask feld [
      set-ground-kind "Rasen"
      set-object-kind "none"
    ]
  ]

  refresh-display
end



to toggle-tartanfeld
  let tartanfeld patches with [
    pxcor >= -23 and pxcor <= -5 and
    pycor >= -22 and pycor <= -10
  ]

  ifelse any? tartanfeld with [ground-kind != "Sportbelag" or object-kind != "none"] [
    ask tartanfeld [
      set-ground-kind "Sportbelag"
      set-object-kind "none"
    ]
  ] [
    ask tartanfeld [
      set-ground-kind "Rasen"
      set-object-kind "none"
    ]
    add-two-trees
  ]

  refresh-display
end

to add-two-trees
  ask patches with [distance patch -21 -16 <= 1] [
    set-ground-kind "Rasen"
    set-object-kind "tree"
  ]

  ask patches with [distance patch -9 -16 <= 1] [
    set-ground-kind "Rasen"
    set-object-kind "tree"
  ]

  refresh-display
end
; ----------------------------------------------------------------------------
; station-air-text
; Reporter für den Lufttemperaturwert einer Station als Monitortext.
; ----------------------------------------------------------------------------
to-report station-air-text [sid]
  let s one-of stations with [station-id = sid]
  if s = nobody [ report "-" ]
  report precision [current-reading] of s 1
end

; ----------------------------------------------------------------------------
; station-surface-text
; Reporter für die Oberflächentemperatur am Stationspatch.
; ----------------------------------------------------------------------------
to-report station-surface-text [sid]
  let s one-of stations with [station-id = sid]
  if s = nobody [ report "-" ]
  report precision [surface-temp] of [patch-here] of s 1
end

; ----------------------------------------------------------------------------
; station-water-text
; Reporter für den absoluten Wasserspeicher am Stationspatch.
; ----------------------------------------------------------------------------
to-report station-water-text [sid]
  let s one-of stations with [station-id = sid]
  if s = nobody [ report "-" ]
  report precision [water-store] of [patch-here] of s 1
end

; ----------------------------------------------------------------------------
; station-waterrel-text
; Reporter für die relative Füllung des Wasserspeichers am Stationspatch.
; ----------------------------------------------------------------------------
to-report station-waterrel-text [sid]
  let s one-of stations with [station-id = sid]
  if s = nobody [ report "-" ]
  let p [patch-here] of s
  if [water-store-max] of p <= 0 [ report "-" ]
  report precision (100 * ([water-store] of p / [water-store-max] of p)) 0
end

; ----------------------------------------------------------------------------
; station-stress-text
; Reporter für den Wasserstress am Stationspatch.
; ----------------------------------------------------------------------------
to-report station-stress-text [sid]
  let s one-of stations with [station-id = sid]
  if s = nobody [ report "-" ]
  report precision [water-stress] of [patch-here] of s 2
end

; ----------------------------------------------------------------------------
; pad-right
; Hilfsfunktion zum rechtsauffüllenden Formatieren von Text.
; ----------------------------------------------------------------------------
to-report pad-right [txt width]
  let s word txt ""
  while [length s < width] [
    set s word s " "
  ]
  if length s > width [
    set s substring s 0 width
  ]
  report s
end

to-report pad-left [txt width]
  let s word txt ""
  while [length s < width] [
    set s word " " s
  ]
  if length s > width [
    set s substring s (length s - width) (length s)
  ]
  report s
end

to-report fmt-col [x]
  if x = "-" [ report pad-left "-" 5 ]
  if is-string? x [ report pad-left x 5 ]
  report pad-left precision x 1 5
end

to-report output-table-separator
  report "+-------+-------+-------+-------+-------+-------+-------+-------+-------+-------+-------+-------+-------+-------+-------+-------+-------+-------+"
end
; ----------------------------------------------------------------------------
; fmt1
; Formatierhilfe für numerische Werte mit einer Nachkommastelle.
; ----------------------------------------------------------------------------
to-report fmt1 [x]
  if x = "-" [ report pad-right "-" 7 ]
  report pad-right precision x 1 7
end

; ----------------------------------------------------------------------------
; fmt0
; Formatierhilfe für numerische Werte ohne Nachkommastelle.
; ----------------------------------------------------------------------------
to-report fmt0 [x]
  report pad-right precision x 0 4
end

; ----------------------------------------------------------------------------
; observer-report-alle-werte
; Zusätzlicher Gesamtbericht aller relevanten Feld- und Dosiswerte im Output.
; ----------------------------------------------------------------------------
to observer-report-alle-werte
  print output-table-separator
  print (word
    "# Kürzel: "
    "Tbg=Hintergrundluft, "
    "TLm/TLx=Feld-Luft Mittel/Max, "
    "TOm/TOx=Feld-Oberfläche Mittel/Max, "
    "BIm/BIx=HitzelastMittel/Max, "
    "HSmh/HSxh=Hitzelast Schulzeit [h], "
    "M1L..M4L=Stations-Luft, "
    "M1O..M4O=Stations-Oberfläche"
  )
  print output-table-separator
end

; ----------------------------------------------------------------------------
; protokolliere-messwerte
; Schreibt eine formatierte Zeile mit Hintergrund-, Luft- und Oberflächenwerten der Stationen in den Output.
to protokolliere-messwerte
  let tl-mean mean [air-temp-local] of patches
  let tl-max  max [air-temp-local] of patches
  let ts-mean mean [surface-temp] of patches
  let ts-max  max [surface-temp] of patches
  let bi-mean mean [comfort-index] of patches
  let bi-max  max [comfort-index] of patches

  let hs-mean mean [heat-dose-comfort] of patches
  let hs-max  max  [heat-dose-comfort] of patches

  if not is-boolean? protokoll-kopf-gedruckt? [
    set protokoll-kopf-gedruckt? false
  ]

  if not protokoll-kopf-gedruckt? [
    clear-output
    print (word "# Simulation: " Versuchsname)
    print output-table-separator
    print "| Zeit  |   Tbg |   TLm |   TLx |   TOm |   TOx |   BIm |   BIx |  HSmh |  HSxh |   M1L |   M2L |   M3L |   M4L |   M1O |   M2O |   M3O |   M4O |"
    print output-table-separator
    set protokoll-kopf-gedruckt? true
  ]

  print (word
    "| " pad-right modell-uhr 5
    " | " fmt-col air-temp
    " | " fmt-col tl-mean
    " | " fmt-col tl-max
    " | " fmt-col ts-mean
    " | " fmt-col ts-max
    " | " fmt-col bi-mean
    " | " fmt-col bi-max
    " | " fmt-col hs-mean
    " | " fmt-col hs-max
    " | " fmt-col station-air-text 1
    " | " fmt-col station-air-text 2
    " | " fmt-col station-air-text 3
    " | " fmt-col station-air-text 4
    " | " fmt-col station-surface-text 1
    " | " fmt-col station-surface-text 2
    " | " fmt-col station-surface-text 3
    " | " fmt-col station-surface-text 4
    " |"
  )
end
; ----------------------------------------------------------------------------
; protokolliere-faellige-stunden
; Protokolliert automatisch alle vollen Stunden, die im Tageslauf bereits erreicht wurden.
; ----------------------------------------------------------------------------
to protokolliere-faellige-stunden
  while [naechste-protokoll-stunde <= 24 and simulationszeit >= naechste-protokoll-stunde] [
    protokolliere-messwerte
    set naechste-protokoll-stunde naechste-protokoll-stunde + 1
  ]

  if simulationszeit >= 24 and naechste-protokoll-stunde > 24 [
    observer-report-alle-werte
  ]
end

; ----------------------------------------------------------------------------
; modell-uhr
; Gibt die aktuelle Modellzeit im Format HH:MM zurück.
; ----------------------------------------------------------------------------
to-report modell-uhr
  let total-minuten round (Stunde * 60)
  let hh floor (total-minuten / 60)
  let mm total-minuten mod 60

  let hh-text (word hh)
  let mm-text (word mm)

  if hh < 10 [ set hh-text (word "0" hh-text) ]
  if mm < 10 [ set mm-text (word "0" mm-text) ]

  report (word hh-text ":" mm-text)
end


; ============================================================================
; Referenzvergleich für ausgewählte Aufenthaltsflächen
; ----------------------------------------------------------------------------
; Diese Logik nutzt die bestehende rechteckige Gebietsauswahl. Sie speichert
; keine komplette Welt und keine Szenarien, sondern nur wenige belastungsrelevante
; Kennwerte pro ausgewähltem Patch. Dadurch bleibt der Vorher/Nachher-Vergleich
; bewusst klein und NetLogo-tauglich.
; ============================================================================

to reset-reference-comparison-globals
  set ref-selection-count 0
  set ref-selection-name ""
  set ref-selection-saved? false
  set ref-heat-mean 0
  set ref-heat-max 0
  set ref-shadow-mean 0
  set ref-air-dose-mean 0
  set ref-surface-dose-mean 0
  set ref-comfort-dose-mean 0
end

to referenz-speichern
  ;; Referenz immer global speichern:
  ;; Die Auswahl ist NICHT mehr Voraussetzung.
  ;; Sie wird nur später für "Auswahl vergleichen" benutzt.

  ask patches [
    set ref-active? true
    set ref-heat-dose-comfort heat-dose-comfort
    set ref-heat-dose-air heat-dose-air
    set ref-heat-dose-surface heat-dose-surface
    set ref-comfort-index comfort-index
    set ref-comfort-index-max comfort-index-max
    set ref-shadow-level shadow-level
  ]

  set ref-selection-count count patches
  set ref-selection-name Szenario-Name
  set ref-selection-saved? true

  set ref-heat-mean mean [heat-dose-comfort] of patches
  set ref-heat-max max [heat-dose-comfort] of patches
  set ref-shadow-mean 100 * mean [shadow-level] of patches
  set ref-air-dose-mean mean [heat-dose-air] of patches
  set ref-surface-dose-mean mean [heat-dose-surface] of patches
  set ref-comfort-dose-mean mean [heat-dose-comfort] of patches

  print "Referenz für die gesamte Karte gespeichert."
  print (word "Mittlere Hitzelast Schulzeit gesamt: " precision ref-heat-mean 2 " h")
  print (word "Maximale Hitzelast Schulzeit gesamt: " precision ref-heat-max 2 " h")
  print "Jetzt Maßnahme aktivieren, Maßnahme setzen, Tageslauf neu starten und erneut simulieren."
end

to auswahl-vergleichen
  let comp comparison-patches

  if not any? comp [
    user-message "Es gibt keine gespeicherte Referenz für die aktuelle Auswahl. Erst 'Referenz speichern' ausführen."
    stop
  ]

  let n count comp
  let mean-before mean [ref-heat-dose-comfort] of comp
  let mean-after mean [heat-dose-comfort] of comp
  let max-before max [ref-heat-dose-comfort] of comp
  let max-after max [heat-dose-comfort] of comp
  let shadow-before 100 * mean [ref-shadow-level] of comp
  let shadow-after 100 * mean [shadow-level] of comp
  let air-before mean [ref-heat-dose-air] of comp
  let air-after mean [heat-dose-air] of comp
  let surf-before mean [ref-heat-dose-surface] of comp
  let surf-after mean [heat-dose-surface] of comp

  let high-before percent-before-at-or-above comp 4
  let high-after percent-after-at-or-above comp 4
  let red-before percent-before-at-or-above comp 5
  let red-after percent-after-at-or-above comp 5
  let lowmid-before percent-before-at-or-below comp 3
  let lowmid-after percent-after-at-or-below comp 3

  print "--- Vergleich ausgewählte Aufenthaltsfläche ---"
  print (word "Rasterfelder: " n)
  print (word "Hitzelast Schulzeit Mittel: " precision mean-before 2 " h -> " precision mean-after 2 " h  (" signed-number (mean-after - mean-before) " h)")
  print (word "Hitzelast Schulzeit Maximum: " precision max-before 2 " h -> " precision max-after 2 " h  (" signed-number (max-after - max-before) " h)")
  print (word "Schattenanteil aktuell: " precision shadow-before 0 "% -> " precision shadow-after 0 "%  (" signed-number (shadow-after - shadow-before) " %-Pkt.)")
  print (word "Luftwärmedosis Mittel: " precision air-before 2 " -> " precision air-after 2 "  (" signed-number (air-after - air-before) ")")
  print (word "Oberflächenwärme Mittel: " precision surf-before 2 " -> " precision surf-after 2 "  (" signed-number (surf-after - surf-before) ")")
  print ""

  print "Kurzbewertung:"
  print (word "Kritische Fläche orange/rot: " precision high-before 0 "% -> " precision high-after 0 "%  (" signed-number (high-after - high-before) " %-Pkt.)")
  print (word "Stark kritische Fläche rot: " precision red-before 0 "% -> " precision red-after 0 "%  (" signed-number (red-after - red-before) " %-Pkt.)")
  print (word "Geringe bis mittlere Hitzelast blau/grün/gelb: " precision lowmid-before 0 "% -> " precision lowmid-after 0 "%  (" signed-number (lowmid-after - lowmid-before) " %-Pkt.)")
  print (word "Verbesserte Fläche insgesamt: " precision (percent-improved comp) 0 "%")
  print (word "Mindestens 1 Klasse besser: " precision (percent-class-improved comp 1) 0 "%")
  print (word "Mindestens 2 Klassen besser: " precision (percent-class-improved comp 2) 0 "%")
  print ""

  print "Klassenwanderung aus kritischen Klassen:"
  print (transition-line comp 5 5 1 4 "rot -> weniger kritisch")
  print (transition-line comp 4 4 1 3 "orange -> gelb/grün/blau")
  print (transition-line comp 4 5 1 3 "orange/rot -> gelb/grün/blau")
  print ""

  print "Detail: Hitzelastklassen Schulzeit:"
  print (comparison-class-line comp 1 "blau <= 1 h")
  print (comparison-class-line comp 2 "grün 1-2.5 h")
  print (comparison-class-line comp 3 "gelb 2.5-5 h")
  print (comparison-class-line comp 4 "orange 5-6.5 h")
  print (comparison-class-line comp 5 "rot > 6.5 h")
  print ""
  print "Hinweis: Mehr gelb ist dann positiv, wenn orange/rot gleichzeitig sinken."

  if Kartenansicht != "Hitzelast Änderung" [
    set Kartenansicht "Hitzelast Änderung"
  ]

  refresh-display
end




to-report percent-before-at-or-above [agentset min-class]
  if not any? agentset [ report 0 ]
  report 100 * count agentset with [
    (hitzelast-class-number ref-heat-dose-comfort) >= min-class
  ] / count agentset
end

to-report percent-after-at-or-above [agentset min-class]
  if not any? agentset [ report 0 ]
  report 100 * count agentset with [
    (hitzelast-class-number heat-dose-comfort) >= min-class
  ] / count agentset
end

to-report percent-before-at-or-below [agentset max-class]
  if not any? agentset [ report 0 ]
  report 100 * count agentset with [
    (hitzelast-class-number ref-heat-dose-comfort) <= max-class
  ] / count agentset
end

to-report percent-after-at-or-below [agentset max-class]
  if not any? agentset [ report 0 ]
  report 100 * count agentset with [
    (hitzelast-class-number heat-dose-comfort) <= max-class
  ] / count agentset
end

to-report transition-percent [agentset from-min from-max to-min to-max]
  if not any? agentset [ report 0 ]
  report 100 * count agentset with [
    (hitzelast-class-number ref-heat-dose-comfort) >= from-min and
    (hitzelast-class-number ref-heat-dose-comfort) <= from-max and
    (hitzelast-class-number heat-dose-comfort) >= to-min and
    (hitzelast-class-number heat-dose-comfort) <= to-max
  ] / count agentset
end

to-report transition-line [agentset from-min from-max to-min to-max label-text]
  report (word label-text ": " precision (transition-percent agentset from-min from-max to-min to-max) 0 "% der Vergleichsfläche")
end




to-report signed-number [x]
  if x > 0 [ report (word "+" precision x 2) ]
  report precision x 2
end

to-report comparison-patches
  report patches with [selected-area? and ref-active?]
end

to-report hitzelast-class-number [v]
  if v <= 1 [ report 1 ]
  if v <= 2.5 [ report 2 ]
  if v <= 5 [ report 3 ]
  if v <= 6.5 [ report 4 ]
  report 5
end

to-report comparison-class-line [agentset class-id label-text]
  let n count agentset
  if n = 0 [ report (word label-text ": 0% -> 0%") ]
  let before-count count agentset with [(hitzelast-class-number ref-heat-dose-comfort) = class-id]
  let after-count count agentset with [(hitzelast-class-number heat-dose-comfort) = class-id]
  let before-percent 100 * before-count / n
  let after-percent 100 * after-count / n
  report (word label-text ": " precision before-percent 0 "% -> " precision after-percent 0 "%  (" signed-number (after-percent - before-percent) " %-Pkt.)")
end

to-report percent-improved [agentset]
  if not any? agentset [ report 0 ]
  report 100 * count agentset with [heat-dose-comfort < ref-heat-dose-comfort] / count agentset
end

to-report percent-class-improved [agentset min-classes]
  if not any? agentset [ report 0 ]
  report 100 * count agentset with [
    ((hitzelast-class-number ref-heat-dose-comfort) - (hitzelast-class-number heat-dose-comfort)) >= min-classes
  ] / count agentset
end


to-report heat-change-color-of [delta]
  ;; delta = aktuell - Referenz. Negative Werte sind Verbesserung.
  if delta <= -2.5 [ report blue - 1 ]
  if delta <= -1.0 [ report green + 1 ]
  if delta < 1.0 [ report gray + 1 ]
  if delta < 2.5 [ report orange + 1 ]
  report red
end

; ============================================================================
; Farbfunktionen und Kartenansichten
; ----------------------------------------------------------------------------
; Dieser Block übersetzt Modellzustände in Farben und steuert die Einfärbung der verschiedenen Kartenansichten.
; ============================================================================

; ----------------------------------------------------------------------------
; recolor-Oberfläche
; Färbt einen Patch in der Oberflächenansicht passend zu Bodenklasse, Objekttyp und Dachstil ein.
; ----------------------------------------------------------------------------
to recolor-Oberfläche  ;; patch context
  if object-kind = "building" [
    if roof-style = "green-roof" [ set pcolor green - 1 stop ]
    if roof-style = "normal-roof" [ set pcolor orange + 3 stop ]
    set pcolor gray + 1
    stop
  ]

  if object-kind = "tree"  [ set pcolor green - 2 stop ]
  if object-kind = "hedge" [ set pcolor green stop ]

  if ground-kind = "none"       [ set pcolor gray + 2 stop ]
  if ground-kind = "Asphalt"    [ set pcolor gray - 2 stop ]
  if ground-kind = "Pflaster"   [ set pcolor gray + 2 stop ]
  if ground-kind = "Offenpflaster"      [ set pcolor 9 stop ]
  if ground-kind = "Sand"       [ set pcolor yellow + 2 stop ]
  if ground-kind = "Sportbelag" [ set pcolor red + 1 stop ]
  if ground-kind = "Rasen"      [ set pcolor green + 1 stop ]
end

; ----------------------------------------------------------------------------
; overlay-facade-on-surface
; Hebt Fassaden in der Oberflächenansicht zusätzlich hervor.
; ----------------------------------------------------------------------------
to overlay-facade-on-surface  ;; patch context
  if object-kind != "building" [ stop ]
  if not any? neighbors4 with [object-kind != "building"] [ stop ]
  if wall-style = "green-wall" [ set pcolor green + 2 stop ]
  set pcolor brown + 2
end

; ----------------------------------------------------------------------------
; recolor-walls
; Färbt Gebäude in der Fassadenansicht nach Wandtyp ein.
; ----------------------------------------------------------------------------
to recolor-walls  ;; patch context
  if object-kind = "building" [
    if any? neighbors4 with [object-kind != "building"] [
      if wall-style = "green-wall" [ set pcolor green + 2 stop ]
      set pcolor brown + 2
      stop
    ]
    set pcolor gray + 1
    stop
  ]

  set pcolor gray + 2
end

; ----------------------------------------------------------------------------
; temperature-color-of
; Farbreporter für Temperaturdifferenzen relativ zur Luft.
; ----------------------------------------------------------------------------
to-report temperature-color-of [temp air]
  let d temp - air
  if d <= 0   [ report sky + 2 ]
  if d <= 2   [ report cyan + 1 ]
  if d <= 4   [ report green + 1 ]
  if d <= 6   [ report lime + 1 ]
  if d <= 8   [ report yellow ]
  if d <= 11  [ report orange + 1 ]
  if d <= 14  [ report orange - 1 ]
  report red + 1
end

; ----------------------------------------------------------------------------
; comfort-color-of
; Farbreporter für den aktuellen Komfortindex.
; ----------------------------------------------------------------------------
to-report comfort-color-of [idx]
  if idx <= 26 [ report blue - 1 ]
  if idx <= 32 [ report green + 1 ]
  if idx <= 38 [ report yellow ]
  if idx <= 44 [ report orange + 1 ]
  report red + 1
end

; ----------------------------------------------------------------------------
; shadow-color-of
; Farbreporter für die Schattenstärke.
; ----------------------------------------------------------------------------
to-report shadow-color-of [s]
  if s <= 0.05 [ report white ]
  if s <= 0.20 [ report sky + 3 ]
  if s <= 0.40 [ report sky + 1 ]
  if s <= 0.60 [ report blue + 2 ]
  if s <= 0.80 [ report blue ]
  report blue - 2
end

; ----------------------------------------------------------------------------
; station-color-of
; Ordnet Stations-IDs feste Plot- und Kartenfarben zu.
; ----------------------------------------------------------------------------
to-report station-color-of [sid]
  let palette [red blue violet orange brown turquoise magenta black green]
  report item ((sid - 1) mod length palette) palette
end

; ----------------------------------------------------------------------------
; building-edge?
; Prüft, ob ein Gebäudepatch am Gebäuderand liegt.
; ----------------------------------------------------------------------------
to-report building-edge?
  report (object-kind = "building") and any? neighbors4 with [object-kind != "building"]
end

; ----------------------------------------------------------------------------
; building-interior?
; Prüft, ob ein Gebäudepatch im Gebäudeinneren liegt.
; ----------------------------------------------------------------------------
to-report building-interior?
  report (object-kind = "building") and not any? neighbors4 with [object-kind != "building"]
end

; ----------------------------------------------------------------------------
; building-shadow-emitter?
; Ein Gebäudepatch wirft nur dann Schatten, wenn in Schattungsrichtung kein weiteres Gebäudepatch liegt.
; ----------------------------------------------------------------------------
to-report building-shadow-emitter?  ;; patch context
  let d-x round (-1 * sin sun-azimuth)
  let d-y round (-1 * cos sun-azimuth)

  if (d-x = 0) and (d-y = 0) [ report false ]

  let downstream patch-at d-x d-y
  if downstream = nobody [ report true ]
  report [object-kind] of downstream != "building"
end

; ----------------------------------------------------------------------------
; groundwater-recharge-mm-pro-stunde
; Einfache explizite Nachlieferung aus tieferem Boden/Grundwasser je Flächentyp.
; ----------------------------------------------------------------------------
to-report groundwater-recharge-mm-pro-stunde  ;; patch context
  let space-factor 0
  if water-store-max > 0 [
    set space-factor max list 0 (1 - (water-store / water-store-max))
  ]

  if object-kind = "tree"  [ report gw-recharge-baum-mm-pro-stunde * space-factor ]
  if object-kind = "hedge" [ report gw-recharge-hecke-mm-pro-stunde * space-factor ]  
  if ground-kind = "Rasen" and object-kind = "none" [ report gw-recharge-rasen-mm-pro-stunde * space-factor ]
  report 0
end
;to-report max-surface-dts-rate  ;; patch context
;  ;; maximale Oberflächentemperaturänderung in °C pro Stunde
;  ;; didaktische Stabilisierung, aber materialabhängig
;
;  if object-kind = "building" [
;    if roof-style = "normal-roof" [ report 5.4 ]
;    if roof-style = "green-roof"  [ report 3.0 ]
;    report 4.0
;  ]
;
;  if object-kind = "tree"  [ report 2.2 ]
;  if object-kind = "hedge" [ report 2.5 ]
;
;  if ground-kind = "Asphalt"      [ report 5.0 ]
;  if ground-kind = "Sportbelag"   [ report 4.6 ]
;  if ground-kind = "Sand"         [ report 4.2 ]
;  if ground-kind = "Pflaster"     [ report 3.4 ]
;  if ground-kind = "Offenpflaster" [ report 3.1 ]
;  if ground-kind = "Rasen"        [ report 2.5 ]
;
;  report 3.8
;end
; ----------------------------------------------------------------------------
; saturation-vapor-pressure-kpa
; Sättigungsdampfdruck in kPa nach Tetens.
; ----------------------------------------------------------------------------
to-report saturation-vapor-pressure-kpa [temp-c]
  report 0.6108 * exp ((17.27 * temp-c) / (temp-c + 237.3))
end


to-report hitzestress-schwelle
  ;; didaktisch-physikalische Einsatzschwelle des aktuellen Aufenthaltsbelastungs-Proxys
  ;; unterhalb davon kein relevanter Hitzestressbeitrag
  if Jahreszeit = "Sommer" [ report 24 ]
  if Jahreszeit = "Frühling/Herbst" [ report 18 ]
  report 8
end

to-report hitzestress-stark
  ;; Bereich, ab dem ein Zeitschritt als voll belastend gewertet wird
  if Jahreszeit = "Sommer" [ report 32 ]
  if Jahreszeit = "Frühling/Herbst" [ report 26 ]
  report 16
end

to-report hitzestress-anteil-aktuell [idx]
  ;; 0..1: intensitätsgewichteter Anteil eines Zeitschritts
  ;; 0 = keine relevante Überschreitung
  ;; 1 = starker Hitzestress über dem oberen Belastungsniveau
  let lo hitzestress-schwelle
  let hi hitzestress-stark
  if hi <= lo [ report 0 ]

  let x (idx - lo) / (hi - lo)
  report max list 0 (min list 1 x)
end

; ----------------------------------------------------------------------------
; air-heat-class / comfort-heat-class / surface-heat-class
; Transparente feste Stufenregeln für Patch-Belastung.
; ----------------------------------------------------------------------------
to-report air-heat-class [ta]
  if Jahreszeit = "Sommer" [
    if ta < 24 [ report 0 ]
    if ta < 26 [ report 0.5 ]
    if ta < 28 [ report 1.2 ]
    if ta < 30 [ report 2.0 ]
    report 3.0
  ]
  if Jahreszeit = "Frühling/Herbst" [
    if ta < 18 [ report 0 ]
    if ta < 20 [ report 0.5 ]
    if ta < 22 [ report 1.2 ]
    if ta < 24 [ report 2.0 ]
    report 3.0
  ]
  if ta < 8 [ report 0 ]
  if ta < 10 [ report 0.5 ]
  if ta < 12 [ report 1.2 ]
  if ta < 14 [ report 2.0 ]
  report 3.0
end

to-report comfort-heat-class [idx]
  if Jahreszeit = "Sommer" [
    if idx < 22 [ report 0 ]
    if idx < 24 [ report 0.5 ]
    if idx < 27 [ report 1.2 ]
    if idx < 30 [ report 2.0 ]
    if idx < 33 [ report 2.7 ]
    report 3.3
  ]
  if Jahreszeit = "Frühling/Herbst" [
    if idx < 16 [ report 0 ]
    if idx < 19 [ report 0.5 ]
    if idx < 22 [ report 1.2 ]
    if idx < 25 [ report 2.0 ]
    report 3.0
  ]
  if idx < 6 [ report 0 ]
  if idx < 9 [ report 0.5 ]
  if idx < 12 [ report 1.2 ]
  if idx < 15 [ report 2.0 ]
  report 3.0
end

to-report surface-heat-class [ts]
  if Jahreszeit = "Sommer" [
    if ts < 26 [ report 0 ]
    if ts < 32 [ report 0.5 ]
    if ts < 38 [ report 1.2 ]
    if ts < 44 [ report 2.0 ]
    if ts < 50 [ report 2.8 ]
    report 3.5
  ]
  if Jahreszeit = "Frühling/Herbst" [
    if ts < 18 [ report 0 ]
    if ts < 24 [ report 0.5 ]
    if ts < 30 [ report 1.2 ]
    if ts < 36 [ report 2.0 ]
    report 3.0
  ]
  if ts < 8 [ report 0 ]
  if ts < 12 [ report 0.5 ]
  if ts < 16 [ report 1.2 ]
  if ts < 20 [ report 2.0 ]
  report 3.0
end

to-report neighbour-heat-boost [ts-neigh]
  if Jahreszeit = "Sommer" [
    if ts-neigh < 28 [ report 0 ]
    if ts-neigh < 34 [ report 0.3 ]
    if ts-neigh < 40 [ report 0.7 ]
    report 1.2
  ]
  if Jahreszeit = "Frühling/Herbst" [
    if ts-neigh < 22 [ report 0 ]
    if ts-neigh < 28 [ report 0.3 ]
    if ts-neigh < 34 [ report 0.7 ]
    report 1.0
  ]
  if ts-neigh < 10 [ report 0 ]
  if ts-neigh < 15 [ report 0.3 ]
  if ts-neigh < 20 [ report 0.7 ]
  report 1.0
end

; -----------------------------------------------------------------------------
; Kennzahlen
; -----------------------------------------------------------------------------

; ----------------------------------------------------------------------------
; t-luft-color-of
; Farbreporter für die aktuelle Lufttemperaturansicht.
; ----------------------------------------------------------------------------
to-report t-luft-color-of [t]
  if Jahreszeit = "Sommer" [
    if t <= 24 [ report blue - 1 ]
    if t <= 28 [ report sky + 1 ]
    if t <= 32 [ report yellow ]
    if t <= 36 [ report orange + 1 ]
    report red + 1
  ]

  if Jahreszeit = "Frühling/Herbst" [
    if t <= 10 [ report blue - 1 ]
    if t <= 15 [ report sky + 1 ]
    if t <= 20 [ report yellow ]
    if t <= 25 [ report orange + 1 ]
    report red + 1
  ]

  if t <= 0 [ report blue - 1 ]
  if t <= 4 [ report sky + 1 ]
  if t <= 8 [ report yellow ]
  if t <= 12 [ report orange + 1 ]
  report red + 1
end

; ----------------------------------------------------------------------------
; t-luft-max-color-of
; Farbreporter für die maximale Lufttemperaturansicht.
; ----------------------------------------------------------------------------
to-report t-luft-max-color-of [t]
  if t <= 26 [ report blue - 1 ]
  if t <= 28 [ report sky + 1 ]
  if t <= 30 [ report yellow ]
  if t <= 32 [ report orange + 1 ]
  report red + 1
end

; ----------------------------------------------------------------------------
; t-surface-color-of
; Farbreporter für die aktuelle Oberflächentemperaturansicht.
; ----------------------------------------------------------------------------
to-report t-surface-color-of [t]
  if Jahreszeit = "Sommer" [
    if t <= 20 [ report blue - 1 ]
    if t <= 30 [ report sky + 1 ]
    if t <= 40 [ report yellow ]
    if t <= 50 [ report orange + 1 ]
    report red + 1
  ]

  if Jahreszeit = "Frühling/Herbst" [
    if t <= 8 [ report blue - 1 ]
    if t <= 18 [ report sky + 1 ]
    if t <= 28 [ report yellow ]
    if t <= 38 [ report orange + 1 ]
    report red + 1
  ]

  if t <= 0 [ report blue - 1 ]
  if t <= 8 [ report sky + 1 ]
  if t <= 16 [ report yellow ]
  if t <= 24 [ report orange + 1 ]
  report red + 1
end

; ----------------------------------------------------------------------------
; t-surface-max-color-of
; Farbreporter für die maximale Oberflächentemperaturansicht.
; ----------------------------------------------------------------------------
to-report t-surface-max-color-of [t]
  if t <= 30 [ report blue - 1 ]
  if t <= 35 [ report sky + 1 ]
  if t <= 40 [ report yellow ]
  if t <= 45 [ report orange + 1 ]
  report red + 1
end

; ----------------------------------------------------------------------------
; t-luft-anomalie-color-of
; Farbreporter für Lufttemperaturabweichungen gegenüber der Hintergrundluft.
; ----------------------------------------------------------------------------
to-report t-luft-anomalie-color-of [d]
  if d <= -2 [ report blue - 1 ]
  if d <= -0.5 [ report sky + 1 ]
  if d <= 0.5 [ report yellow ]
  if d <= 2 [ report orange + 1 ]
  report red + 1
end

; ----------------------------------------------------------------------------
; t-delta-color-of
; Farbreporter für die Differenz zwischen Oberfläche und lokaler Luft.
; ----------------------------------------------------------------------------
to-report t-delta-color-of [d]
  if d <= 0 [ report blue - 1 ]
  if d <= 3 [ report sky + 1 ]
  if d <= 7 [ report yellow ]
  if d <= 12 [ report orange + 1 ]
  report red + 1
end

; ----------------------------------------------------------------------------
; comfort-max-color-of
; Farbreporter für die maximale Belastung.
; ----------------------------------------------------------------------------
to-report comfort-max-color-of [idx]
  if idx <= 28 [ report blue - 1 ]
  if idx <= 34 [ report green + 1 ]
  if idx <= 40 [ report yellow ]
  if idx <= 46 [ report orange + 1 ]
  report red + 1
end

; ----------------------------------------------------------------------------
; heat-dose-air-color-of
; Farbreporter für die kumulierte Luftwärmedosis.
; ----------------------------------------------------------------------------
to-report heat-dose-air-color-of [x]
  if x <= 2 [ report blue - 1 ]
  if x <= 6 [ report green + 1 ]
  if x <= 12 [ report yellow ]
  if x <= 20 [ report orange + 1 ]
  report red + 1
end

; ----------------------------------------------------------------------------
; heat-dose-surface-color-of
; Farbreporter für die kumulierte Oberflächenwärmedosis.
; ----------------------------------------------------------------------------
to-report heat-dose-surface-color-of [x]
  if x <= 1 [ report blue - 1 ]
  if x <= 5 [ report green + 1 ]
  if x <= 15 [ report yellow ]
  if x <= 35 [ report orange + 1 ]
  report red + 1
end

; ----------------------------------------------------------------------------
; comfort-dose-color-of
; Farbreporter für die kumulierte Hitzebelastung.
; ----------------------------------------------------------------------------
to-report comfort-dose-color-of [x]
  if x <= 1.0 [ report blue - 1 ]
  if x <= 2.5 [ report green + 1 ]
  if x <= 5.0 [ report yellow ]
  if x <= 6.5 [ report orange + 1 ]
  report red + 1
end

; ----------------------------------------------------------------------------
; wasserstress-color-of
; Farbreporter für echten Wasserstress.
; ----------------------------------------------------------------------------
to-report wasserstress-color-of [s]
  ;; s = echter Stress, also 0 = kein Stress, 1 = maximaler Stress
  if s <= 0.2 [ report blue - 1 ]
  if s <= 0.4 [ report green + 1 ]
  if s <= 0.6 [ report yellow ]
  if s <= 0.8 [ report orange + 1 ]
  report red + 1
end

; ----------------------------------------------------------------------------
; wasserfuellung-color-of
; Farbreporter für die relative Wasserfüllung.
; ----------------------------------------------------------------------------
to-report wasserfuellung-color-of [r]
  ;; r = relative Füllung 0..1
  if r <= 0.2 [ report brown + 2 ]
  if r <= 0.4 [ report orange + 1 ]
  if r <= 0.6 [ report yellow ]
  if r <= 0.8 [ report green + 1 ]
  report blue + 1
end

; ----------------------------------------------------------------------------
; wasserspeicher-color-of
; Farbreporter für den absoluten Wasserspeicher.
; ----------------------------------------------------------------------------
to-report wasserspeicher-color-of [mm]
  ;; absoluter Speicherinhalt in mm
  if mm <= 0.05 [ report brown + 2 ]
  if mm <= 1.0 [ report orange + 1 ]
  if mm <= 5.0 [ report yellow ]
  if mm <= 15.0 [ report green + 1 ]
  report blue + 1
end

; ----------------------------------------------------------------------------
; recolor-world
; Zentrale Umschaltfunktion für alle Kartenansichten und ihre Legenden.
; ----------------------------------------------------------------------------
to recolor-world
  if Kartenansicht = "Materialien & Elemente" [
    ask patches [ recolor-Oberfläche ]
    ask patches [ overlay-facade-on-surface ]
    ifelse Legende-an? [ draw-legend-klein-surface ] [ legende-loeschen ]
    stop
  ]

  if Kartenansicht = "Schatten aktuell" [
    ask patches [ set pcolor shadow-color-of shadow-level ]
    ifelse Legende-an? [ draw-legend-schatten-klein ] [ legende-loeschen ]
    stop
  ]

  if Kartenansicht = "Oberflächentemperatur aktuell" [
    ask patches [ set pcolor t-surface-color-of surface-temp ]
    ifelse Legende-an? [ draw-legend-tsurface-klein ] [ legende-loeschen ]
    stop
  ]

  if Kartenansicht = "Lufttemperatur aktuell" [
    ask patches [ set pcolor t-luft-color-of air-temp-local ]
    ifelse Legende-an? [ draw-legend-tluft-klein ] [ legende-loeschen ]
    stop
  ]

  if Kartenansicht = "Hitzelast aktuell" [
    ask patches [ set pcolor comfort-color-of comfort-index ]
    ifelse Legende-an? [ draw-legend-belastung-klein ] [ legende-loeschen ]
    stop
  ]

  if Kartenansicht = "Hitzelast Schulzeit" [
    ask patches [ set pcolor comfort-dose-color-of heat-dose-comfort ]
    ifelse Legende-an? [ draw-legend-Hitzebelastung-klein ] [ legende-loeschen ]
    stop
  ]

  if Kartenansicht = "Hitzelast Änderung" [
    ask patches [
      ifelse ref-active? [
        set pcolor heat-change-color-of (heat-dose-comfort - ref-heat-dose-comfort)
      ] [
        set pcolor gray + 3
      ]
    ]
    ifelse Legende-an? [ draw-legend-hitzelast-aenderung-klein ] [ legende-loeschen ]
    stop
  ]

  legende-loeschen

  ask patches with [selected-area?] [
    set plabel "□"
    set plabel-color black
  ]
  ask patches with [not selected-area?] [
    if plabel = "□" [ set plabel "" ]
  ]
end


to draw-selection-overlay
  ask patches with [selected-area?] [
    set plabel "□"
    set plabel-color red
  ]
  ask patches with [not selected-area?] [
    if plabel = "□" [ set plabel "" ]
  ]
end
; ============================================================================
; Legendenfunktionen
; ----------------------------------------------------------------------------
; Hier werden die verschiedenen kleinen Legenden der Kartenansichten aufgebaut.
; Die Funktionen erzeugen ausschließlich Anzeigeelemente und ändern keine
; Modelllogik.
; Für die verkleinerte Welt (-25 bis 25) sind die Positionen kompakter gesetzt.
; ============================================================================

; ----------------------------------------------------------------------------
; legend-clear-x-min
; Hilfsreporter für die linke Begrenzung des Legendenbereichs.
; ----------------------------------------------------------------------------
to-report legend-clear-x-min
  report max-pxcor - 8
end

; ----------------------------------------------------------------------------
; legend-clear-y-min
; Hilfsreporter für die untere Begrenzung des Legendenbereichs.
; ----------------------------------------------------------------------------
to-report legend-clear-y-min
  report max-pycor - 15
end

; ----------------------------------------------------------------------------
; legend-title-x
; Hilfsreporter für die x-Position des Legendtitels.
; ----------------------------------------------------------------------------
to-report legend-title-x
  report max-pxcor - 3
end

; ----------------------------------------------------------------------------
; legend-title-y
; Hilfsreporter für die y-Position des Legendtitels.
; ----------------------------------------------------------------------------
to-report legend-title-y
  report max-pycor - 1
end

; ----------------------------------------------------------------------------
; legend-patch-box-x
; Hilfsreporter für die x-Position der farbigen Legendenfelder.
; ----------------------------------------------------------------------------
to-report legend-patch-box-x
  report max-pxcor - 6
end

; ----------------------------------------------------------------------------
; legend-patch-text-x
; Hilfsreporter für die x-Position der Legendentexte.
; ----------------------------------------------------------------------------
to-report legend-patch-text-x
  report max-pxcor - 2
end

; ----------------------------------------------------------------------------
; legend-patch-y-top
; Hilfsreporter für die obere y-Position der großen Legende.
; ----------------------------------------------------------------------------
to-report legend-patch-y-top
  report max-pycor - 3
end

; ----------------------------------------------------------------------------
; legend-station-y-start
; Hilfsreporter für die Startposition der Stationslegende.
; ----------------------------------------------------------------------------
to-report legend-station-y-start
  report max-pycor - 9
end

; ----------------------------------------------------------------------------
; legend-station-y-min
; Hilfsreporter für die minimale y-Position der Stationslegende.
; ----------------------------------------------------------------------------
to-report legend-station-y-min
  report max-pycor - 15
end

; ----------------------------------------------------------------------------
; legend-small-box-x
; Hilfsreporter für die x-Position der kleinen Legendenkästchen.
; ----------------------------------------------------------------------------
to-report legend-small-box-x
  report max-pxcor - 5
end

; ----------------------------------------------------------------------------
; legend-small-text-x
; Hilfsreporter für die x-Position der kleinen Legendentexte.
; ----------------------------------------------------------------------------
to-report legend-small-text-x
  report max-pxcor - 1
end

; ----------------------------------------------------------------------------
; legend-small-y-top
; Hilfsreporter für die obere y-Position kleiner Legenden.
; ----------------------------------------------------------------------------
to-report legend-small-y-top
  report max-pycor - 1
end

; ----------------------------------------------------------------------------
; legend-small-dy
; Hilfsreporter für den vertikalen Abstand kleiner Legendenzeilen.
; ----------------------------------------------------------------------------
to-report legend-small-dy
  report 1
end


to-report percent-before-yellow [agentset]
  if not any? agentset [ report 0 ]

  let n count agentset
  let c count agentset with [
    (hitzelast-class-number ref-heat-dose-comfort) = 3
  ]

  report 100 * c / n
end

to-report percent-after-yellow [agentset]
  if not any? agentset [ report 0 ]

  let n count agentset
  let c count agentset with [
    (hitzelast-class-number heat-dose-comfort) = 3
  ]

  report 100 * c / n
end

to-report percent-before-orange [agentset]
  if not any? agentset [ report 0 ]

  let n count agentset
  let c count agentset with [
    (hitzelast-class-number ref-heat-dose-comfort) = 4
  ]

  report 100 * c / n
end

to-report percent-after-orange [agentset]
  if not any? agentset [ report 0 ]

  let n count agentset
  let c count agentset with [
    (hitzelast-class-number heat-dose-comfort) = 4
  ]

  report 100 * c / n
end

to-report report-orange-area [comp]
  let before precision percent-before-orange comp 0
  let after precision percent-after-orange comp 0
  report (word "orange: " before "% -> " after "% ")
end


to-report report-yellow-area [comp]
  let before precision percent-before-yellow comp 0
  let after precision percent-after-yellow comp 0
  report (word "gelb: " before "% -> " after "% ")
end

to-report report-critical-area [comp]
  let before percent-before-at-or-above comp 4
  let after percent-after-at-or-above comp 4
  report (word "orange/rot: "
    precision before 0 "% -> "
    precision after 0 "%  ")
end

to-report report-lowmid-area [comp]
  let before percent-before-at-or-below comp 2
  let after percent-after-at-or-below comp 2
  report (word "blau/grün: "
    precision before 0 "% -> "
    precision after 0 "%  ")
end

to-report report-red-area [comp]
  let before percent-before-at-or-above comp 5
  let after percent-after-at-or-above comp 5
  report (word "rot: "
    precision before 0 "% -> "
    precision after 0 "% ")
end

to-report report-improvement-summary [comp]
  report (word
    "Verbesserte Fläche: " precision (percent-improved comp) 0 "% | "
    "Min 1 Klasse ⇧: " precision (percent-class-improved comp 1) 0 "% | "
    "Min 2 Klassen ⇧: " precision (percent-class-improved comp 2) 0 "%")
end

to-report percent-worsened [agentset]
  if not any? agentset [ report 0 ]
  report 100 * count agentset with [
    heat-dose-comfort > ref-heat-dose-comfort
  ] / count agentset
end

to-report percent-class-worsened [agentset min-classes]
  if not any? agentset [ report 0 ]
  report 100 * count agentset with [
    ((hitzelast-class-number heat-dose-comfort) - (hitzelast-class-number ref-heat-dose-comfort)) >= min-classes
  ] / count agentset
end

to-report report-worsened-area [comp]
  report (word "Verschlechtert: " precision (percent-worsened comp) 0 "%")
end

to-report report-one-class-worse [comp]
  report (word "↑ 1 Klasse schlechter: " precision (percent-class-worsened comp 1) 0 "%")
end

to-report report-two-classes-worse [comp]
  report (word "↑ 2 Klassen schlechter: " precision (percent-class-worsened comp 2) 0 "%")
end

; ----------------------------------------------------------------------------
; draw-legend
; Zeichnet die große kombinierte Legende für Oberflächen und Stationen.
; ----------------------------------------------------------------------------
to draw-legend
  let clear-x-min legend-clear-x-min
  let clear-y-min legend-clear-y-min
  let title-x legend-title-x
  let title-y legend-title-y
  let box-x legend-patch-box-x
  let text-x legend-patch-text-x
  let y-top legend-patch-y-top

  ask patches with [pxcor >= clear-x-min and pycor >= clear-y-min] [
    set pcolor white
    set plabel ""
    set plabel-color black
  ]

  ask patch title-x title-y [
    set plabel "Legende"
    set plabel-color black
  ]

  ask patch box-x y-top [ set pcolor gray - 2 ]
  ask patch text-x y-top [ set plabel "Asphalt" ]

  ask patch box-x (y-top - 2) [ set pcolor gray + 2 ]
  ask patch text-x (y-top - 2) [ set plabel "Pflaster" ]

  ask patch box-x (y-top - 4) [ set pcolor 9 ]
  ask patch text-x (y-top - 4) [ set plabel "Offenpflaster" ]

  ask patch box-x (y-top - 6) [ set pcolor red + 1 ]
  ask patch text-x (y-top - 6) [ set plabel "Sportbelag" ]

  ask patch box-x (y-top - 8) [ set pcolor green - 1 ]
  ask patch text-x (y-top - 8) [ set plabel "Hecke" ]

  ask patch box-x (y-top - 10) [ set pcolor green + 1 ]
  ask patch text-x (y-top - 10) [ set plabel "Rasen" ]

  ask patch box-x (y-top - 12) [ set pcolor green - 2 ]
  ask patch text-x (y-top - 12) [ set plabel "Baum" ]

  ask patch box-x (y-top - 14) [ set pcolor orange + 3 ]
  ask patch text-x (y-top - 14) [ set plabel "Gebäude" ]

  ask patch box-x (y-top - 16) [ set pcolor brown + 2 ]
  ask patch text-x (y-top - 16) [ set plabel "Fassade" ]

  let y legend-station-y-start
  let ordered-stations sort-by [[a b] -> [station-id] of a < [station-id] of b] stations
  foreach ordered-stations [ s ->
    if y >= legend-station-y-min [
      ask patch box-x y [ set pcolor [station-color] of s ]
      ask patch text-x y [ set plabel [label] of s ]
      set y y - 1
    ]
  ]
end

; ----------------------------------------------------------------------------
; draw-legend-klein-surface
; Zeichnet die kompakte Legende der Oberflächenansicht.
; ----------------------------------------------------------------------------
to draw-legend-klein-surface
  ask patches with [pxcor >= legend-clear-x-min and pycor >= legend-clear-y-min] [
    set plabel ""
    set plabel-color black
  ]

  let x-box legend-small-box-x
  let x-text legend-small-text-x
  let y-top legend-small-y-top
  let d-y legend-small-dy
  let eintraege (list
    (list (gray - 2) "Asphalt")
    (list (gray + 2) "Pflaster")
    (list (lime + 2) "Offenpfl.")
    (list (red + 1) "Sport")
    (list (green + 1) "Rasen")
    (list green "Hecke")
    (list (green - 2) "Baum")
    (list (orange + 3) "Dach")
  )

  let i 0
  while [i < length eintraege] [
    let e-var item i eintraege
    let farbe item 0 e-var
    let label-text item 1 e-var
    let ypos y-top - i * d-y
    ask patch x-box ypos [ set pcolor farbe ]
    ask patch x-text ypos [ set plabel label-text set plabel-color black ]
    set i i + 1
  ]
end

; ----------------------------------------------------------------------------
; draw-legend-temperatur-klein
; Zeichnet die kompakte Legende der älteren Temperaturansicht.
