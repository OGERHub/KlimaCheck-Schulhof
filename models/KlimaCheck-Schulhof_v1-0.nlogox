    set plabel ""
    set plabel-color black
  ]
end

; ----------------------------------------------------------------------------
; draw-legend-5class-klein
; Generische Hilfsfunktion zum Zeichnen kompakter fünfklassiger Legenden.
; ----------------------------------------------------------------------------
to draw-legend-5class-klein [entries]
  ask patches with [pxcor >= legend-clear-x-min and pycor >= legend-clear-y-min] [
    set plabel ""
    set plabel-color black
  ]

  let x-box legend-small-box-x
  let x-text legend-small-text-x
  let y-top legend-small-y-top
  let d-y legend-small-dy

  let i 0
  while [i < length entries] [
    let et item i entries
    let farbe item 0 et
    let label-text item 1 et
    let ypos y-top - i * d-y

    ask patch x-box ypos [ set pcolor farbe ]
    ask patch x-text ypos [
      set plabel label-text
      set plabel-color black
    ]

    set i i + 1
  ]
end

