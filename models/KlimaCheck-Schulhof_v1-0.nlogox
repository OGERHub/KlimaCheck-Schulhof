  let eintraege (list
    (list (sky + 2) "≤ Hgrd")
    (list (cyan + 1) "0-2°")
    (list (green + 1) "2-4°")
    (list (lime + 1) "4-6°")
    (list yellow "6-8°")
    (list (orange + 1) "8-11°")
    (list (orange - 1) "11-14°")
    (list (red + 1) ">14°")
  )

  let i 0
  while [i < length eintraege] [
    let e-var item i eintraege
    let farbe item 0 e-var
    let label-text item 1 e-var
    let ypos y-top - i * d-y
    ask patch x-box ypos [ set pcolor farbe ]
    ask patch x-text ypos [ set plabel label-text set plabel-color black ]
    set i i + 1
  ]
end

