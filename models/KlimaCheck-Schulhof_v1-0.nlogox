to-report aufenthaltsflaechen
  report patches with [
    object-kind = "none" and
    member? ground-kind ["Asphalt" "Pflaster" "Offenpflaster" "Rasen" "Sportbelag" "Sand"]
  ]
end

to-report hitzelast-klasse-blau
  report aufenthaltsflaechen with [heat-dose-comfort <= 1]
end

to-report hitzelast-klasse-gruen
  report aufenthaltsflaechen with [heat-dose-comfort > 1 and heat-dose-comfort <= 2.5]
end

to-report hitzelast-klasse-gelb
  report aufenthaltsflaechen with [heat-dose-comfort > 2.5 and heat-dose-comfort <= 5]
end

to-report hitzelast-klasse-orange
  report aufenthaltsflaechen with [heat-dose-comfort > 5 and heat-dose-comfort <= 6.5]
end

to-report hitzelast-klasse-rot
  report aufenthaltsflaechen with [heat-dose-comfort > 6.5]
end


to-report prozent-hitzelast-blau
  let a aufenthaltsflaechen
  if not any? a [ report 0 ]
  report 100 * count hitzelast-klasse-blau / count a
end

to-report prozent-hitzelast-gruen
  let a aufenthaltsflaechen
  if not any? a [ report 0 ]
  report 100 * count hitzelast-klasse-gruen / count a
end

to-report prozent-hitzelast-gelb
  let a aufenthaltsflaechen
  if not any? a [ report 0 ]
  report 100 * count hitzelast-klasse-gelb / count a
end

to-report prozent-hitzelast-orange
  let a aufenthaltsflaechen
  if not any? a [ report 0 ]
  report 100 * count hitzelast-klasse-orange / count a
end

to-report prozent-hitzelast-rot
  let a aufenthaltsflaechen
  if not any? a [ report 0 ]
  report 100 * count hitzelast-klasse-rot / count a
end
to setup-hitzelastklassen-plot
  set-current-plot "Hitzelastklassen Aufenthaltsflächen"
  clear-plot
  auto-plot-off
  set-plot-x-range 1 5
  set-plot-y-range 0 50
end

to update-hitzelastklassen-plot
  set-current-plot "Hitzelastklassen Aufenthaltsflächen"
  clear-plot
  auto-plot-off
  set-plot-x-range 0 6
  set-plot-y-range 0 100

  create-temporary-plot-pen "<=1 h"
  set-plot-pen-color blue - 1
  set-plot-pen-mode 1
  plotxy 1 prozent-hitzelast-blau

  create-temporary-plot-pen "1-2.5 h"
  set-plot-pen-color green + 1
  set-plot-pen-mode 1
  plotxy 2 prozent-hitzelast-gruen

  create-temporary-plot-pen "2.5-5 h"
  set-plot-pen-color yellow
  set-plot-pen-mode 1
  plotxy 3 prozent-hitzelast-gelb

  create-temporary-plot-pen "5-6.5 h"
  set-plot-pen-color orange + 1
  set-plot-pen-mode 1
  plotxy 4 prozent-hitzelast-orange

  create-temporary-plot-pen ">6.5 h"
  set-plot-pen-color red + 1
  set-plot-pen-mode 1
  plotxy 5 prozent-hitzelast-rot
end

; ============================================================================
; Schalter für globale Begrünung
; ----------------------------------------------------------------------------
; Dieser Block enthält globale Umschalter für Dach- und Fassadenbegrünung im gesamten Modell.
; ============================================================================

; ----------------------------------------------------------------------------
; toggle-alle-daecher
; Schaltet alle Dächer global zwischen normal und begrünt um.
; ----------------------------------------------------------------------------
to toggle-alle-daecher
  ifelse any? patches with [object-kind = "building" and roof-style = "normal-roof"] [
    ask patches with [object-kind = "building"] [ apply-roof-style "green-roof" ]
  ] [
    ask patches with [object-kind = "building"] [ apply-roof-style "normal-roof" ]
  ]
  refresh-display
end

; ----------------------------------------------------------------------------
; toggle-alle-waende
; Schaltet alle Fassaden global zwischen normal und begrünt um.
; ----------------------------------------------------------------------------
to toggle-alle-waende
  ifelse any? patches with [building-edge? and wall-style = "normal-wall"] [
    ask patches with [building-edge?] [
      apply-wall-style "green-wall"
    ]
  ] [
    ask patches with [building-edge?] [
      apply-wall-style "normal-wall"
    ]
  ]
  refresh-display
end


