; ============================================================================
; Geometrieexport und gespeicherte Referenzgeometrie
; ----------------------------------------------------------------------------
; Hier liegen die Hilfsfunktionen zum Verdichten der Welt in Rechteckgeometrien, zum Export in Reporterform und die aktuell fest eingetragene Referenzgeometrie.
; ============================================================================

; ----------------------------------------------------------------------------
; same-geom?
; Vergleicht, ob ein Patch die gleiche geometrisch-semantische Signatur wie eine Referenzsignatur besitzt.
; ----------------------------------------------------------------------------
to-report same-geom? [p sig]
  report
    [ground-kind] of p = item 0 sig and
    [object-kind] of p = item 1 sig and
    [roof-style] of p = item 2 sig and
    [wall-style] of p = item 3 sig and
    [building-height] of p = item 4 sig and
    [veg-height] of p = item 5 sig
end

; ----------------------------------------------------------------------------
; patch-geom-sig
; Erzeugt die geometrisch-semantische Signatur eines Patches.
; ----------------------------------------------------------------------------
to-report patch-geom-sig [p]
  report (list
    [ground-kind] of p
    [object-kind] of p
    [roof-style] of p
    [wall-style] of p
    [building-height] of p
    [veg-height] of p
  )
end

; ----------------------------------------------------------------------------
; extract-geometry-rects
; Verdichtet die aktuelle Welt in rechteckige Blöcke gleicher Geometriesignatur.
; ----------------------------------------------------------------------------
to-report extract-geometry-rects
  ask patches [ set geom-done? false ]

  let rects []
  let y max-pycor

  while [y >= min-pycor] [
    let x min-pxcor

    while [x <= max-pxcor] [
      let p patch x y

      if not [geom-done?] of p [
        let sig patch-geom-sig p

        ;; maximale Breite nach rechts
        let w 0
        while [
          (x + w <= max-pxcor) and
          (not [geom-done?] of (patch (x + w) y)) and
          same-geom? (patch (x + w) y) sig
        ] [
          set w w + 1
        ]

        ;; maximale Höhe nach unten
        let h 1
        let can-grow true

        while [can-grow and (y - h >= min-pycor)] [
          let xx x
          while [can-grow and (xx < x + w)] [
            let q patch xx (y - h)
            if [geom-done?] of q or not same-geom? q sig [
              set can-grow false
            ]
            set xx xx + 1
          ]
          if can-grow [
            set h h + 1
          ]
        ]

        ;; Rechteck markieren
        ask patches with [
          pxcor >= x and pxcor < (x + w) and
          pycor <= y and pycor > (y - h)
        ] [
          set geom-done? true
        ]

        ;; Format:
        ;; [x1 x2 y1 y2 ground-kind object-kind roof-style wall-style building-height veg-height]
        set rects lput
          (sentence (list x (x + w - 1) (y - h + 1) y) sig)
          rects
      ]

      set x x + 1
    ]

    set y y - 1
  ]

  ask patches [ set geom-done? false ]
  report rects
end

; ----------------------------------------------------------------------------
; write-geometry-rects
; Schreibt eine extrahierte Rechteckgeometrie als NetLogo-Reporter in eine Datei.
; ----------------------------------------------------------------------------
to write-geometry-rects [path reporter-name]
  let rects extract-geometry-rects

  file-close-all
  file-open path
  file-print (word "to-report " reporter-name)
  file-print "  report ["

  foreach rects [ r ->
    file-type "    ["
    let i 0
    while [i < length r] [
      let v item i r
      ifelse is-string? v
        [ file-type (word "\"" v "\"") ]
        [ file-type v ]
      if i < (length r - 1) [ file-type " " ]
      set i i + 1
    ]
    file-print "]"
  ]

  file-print "  ]"
  file-print "end"
  file-close
end
;write-geometry-rects "geometry_modell2.nls" "geometry-rects-modell2"
; reinkopieren
to szenario-speichern
  synchronisiere-szenario-name

  if not is-string? Szenario-Name [ stop ]
  if empty? trim Szenario-Name [ stop ]

  let base (word "scenario_" trim Szenario-Name)
  let geom-file   (word base "_geom.txt")
  let report-file (word base "_report.txt")

  let rects extract-geometry-rects

  file-close-all
  if file-exists? geom-file [ file-delete geom-file ]
  file-open geom-file
  file-write rects
  file-close

  if file-exists? report-file [ file-delete report-file ]
  export-output report-file

  index-szenario Szenario-Name

  set Aktive-Geometrie-Datei geom-file
  szenarien-anzeigen
  user-message (word "Szenario gespeichert: " base)
end
to index-szenario [name]
  let clean-name trim name
  if empty? clean-name [ stop ]

  let idx-file "scenario_index.txt"
  let existing []

  file-close-all
  if file-exists? idx-file [
    file-open idx-file
    while [not file-at-end?] [
      let line trim file-read-line
      if line != "" [
        set existing lput line existing
      ]
    ]
    file-close
  ]

  if not member? clean-name existing [
    if file-exists? idx-file [ file-delete idx-file ]
    file-open idx-file
    foreach sentence existing (list clean-name) [ entry ->
      file-print entry
    ]
    file-close
  ]
end
to szenarien-anzeigen
  let idx-file "scenario_index.txt"

  clear-output

  if not file-exists? idx-file [
    output-print "Keine Szenarien im Index."
    stop
  ]

  file-close-all
  file-open idx-file

  output-print "Gespeicherte Versuche:"
  output-print "---------------------"

  while [not file-at-end?] [
    let entry trim file-read-line
    if entry != "" [
      output-print entry
    ]
  ]

  file-close
end

to szenario-laden
  synchronisiere-szenario-name
  let fname (word "scenario_" trim Szenario-Name "_geom.txt")

  if not file-exists? fname [
    user-message (word "Datei nicht gefunden: " fname)
    stop
  ]

  file-close-all
  file-open fname
  let rects file-read
  file-close

  set Aktive-Geometrie-Datei fname

  clear-stations
  build-world-from-rects rects
  rebuild-derived-fields
  cast-shadows
  recolor-world
  refresh-station-appearance
  update-indicators
  update-station-readings
  display

  user-message (word "Szenario geladen: " fname)
end

to-report trim [s]
  let out s
  while [length out > 0 and substring out 0 1 = " "] [
    set out substring out 1 length out
  ]
  while [length out > 0 and substring out (length out - 1) length out = " "] [
    set out substring out 0 (length out - 1)
  ]
  report out
end

to synchronisiere-szenario-name
  if not is-string? Versuchsname [ set Versuchsname "Standard" ]
  if empty? trim Versuchsname [ set Versuchsname "Standard" ]
  set Szenario-Name trim Versuchsname
end
