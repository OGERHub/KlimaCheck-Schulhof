<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.0" snapToGrid="true">
  <code><![CDATA[; =============================================================================
; Schulhofklima 2D
; Vereinfachtes didaktisches Mikroklima-Modell für Schulhof-Workshops
; =============================================================================
; -----------------------------------------------------------------------------
; INHALTSVERZEICHNIS / ORIENTIERUNG
; -----------------------------------------------------------------------------
; Dieses Modell beschreibt ein vereinfachtes didaktisches Mikroklima-Modell für
; einen Schulhof. 
;
; HAUPTBEREICHE DES CODES
;  1. Modellidee und Grunddeklarationen
;     - breed-Deklarationen
;     - stations-own
;     - globals
;     - patches-own
;
;  2. Hauptablauf und Benutzerinteraktion
;     - setup
;     - go
;     - interaktiv
;     - refresh-display
;     - Button-Wrapper und Simulationsabläufe
;
;  3. Defaults, Reset und vorbereitende Hilfen
;     - Standardwerte absichern
;     - Demo-/Leerszenen zurücksetzen
;     - Komfortfunktionen für Tageszeiten
;
;  4. Szenenaufbau und Geometrie
;     - Demo-Schulhof aufbauen
;     - Rechteckbasierte Weltgeometrie laden
;     - Referenzgeometrie als geometry-rects
;
;  5. Patch-Initialisierung und Materiallogik
;     - Bodenklassen
;     - Objektklassen
;     - Dach- und Wandstile
;     - Wasserspeicherparameter
;
;  6. Abgeleitete räumliche Felder
;     - Vegetationseinfluss
;     - Wandkontext
;     - räumliche Einfassung
;     - vereinfachter Belastungsindex
;
;  7. Sonnenstand, Schatten und Thermik
;     - Tagesgang
;     - Sonnengeometrie
;     - Schattenwurf
;     - Update des thermischen Zustands
;
;  8. Interaktive Bearbeitung und Messstationen
;     - Mausinteraktion
;     - Flächenbearbeitung
;     - Stationssetzen / Stationslöschen
;     - Gebietsauswahl
;
;  9. Plotaufbau, Indikatoren und Protokollierung
;     - Stationsdiagramm
;     - Kennzahlen
;     - Textausgaben / Messprotokolle
;
; 10. Kartenansichten und Farblogik
;     - Oberflächenansicht
;     - Temperatur- und Belastungsansichten
;     - Wasser- und Schattenansichten
;     - Fassadenansicht
;
; 11. Legendenfunktionen
;     - kleine Legenden
;     - Hilfsreporter für Positionierung
;
; 12. Globale Umschalter
;     - alle Dächer umschalten
;     - alle Wände umschalten
;
; 13. Geometrieexport
;     - Welt wieder in Rechtecklisten zurückführen
;     - Export in Reporterform
;
; 14. Fest gespeicherte Referenzgeometrie
;     - geometry-rects
;
; LESEHINWEIS
; - "ground-kind" beschreibt die Bodenklasse eines Patches.
; - "object-kind" beschreibt, ob auf dem Patch ein Objekt liegt
;   (z. B. Gebäude, Baum, Hecke).
; - Viele Anzeigen sind bewusst didaktisch vereinfacht und nicht als exakte
;   physikalische Realität zu verstehen.
; =============================================================================

; -----------------------------------------------------------------------------
; Agententypen (breeds)
; -----------------------------------------------------------------------------
; stations         = eigentliche Messstationen im Modell
; legendenfelder   = optional nutzbare Hilfsagenten für Legendenelemente
; legendentexte    = optional nutzbare Hilfsagenten für Textbestandteile
; -----------------------------------------------------------------------------
breed [stations station]
breed [legendenfelder legendenfeld]
breed [legendentexte legendentext]

; -----------------------------------------------------------------------------
; Eigene Variablen der Messstationen
; -----------------------------------------------------------------------------
; station-id      = laufende Stationsnummer (M1, M2, M3, ...)
; station-color   = feste Darstellungs- und Plotfarbe der Station
; current-reading = aktueller ausgelesener Messwert der lokalen Lufttemperatur
; -----------------------------------------------------------------------------
stations-own [
  station-id
  station-color
  current-reading
]

; -----------------------------------------------------------------------------
; Globale Modellvariablen
; -----------------------------------------------------------------------------
; In diesem Block stehen alle Zustände, die nicht nur zu einem einzelnen Patch
; oder zu einer einzelnen Station gehören, sondern das Gesamtmodell, die
; Bedienung oder die Auswertung betreffen.
; -----------------------------------------------------------------------------
globals [
  
  Legende-an?

  ;; Zustand und Kennwerte einer rechteckigen Gebietsauswahl
  selection-active?
  selection-start-patch
  selection-end-patch

  sel-count
  sel-air-mean
  sel-air-max
  sel-surface-mean
  sel-surface-max
  sel-comfort-mean
  sel-comfort-max

  sel-heat-air-sum
  sel-heat-surface-sum
  sel-heat-comfort-sum

  ;; Referenzvergleich für ausgewählte Aufenthaltsflächen
  ref-selection-count
  ref-selection-name
  ref-selection-saved?
  ref-heat-mean
  ref-heat-max
  ref-shadow-mean
  ref-air-dose-mean
  ref-surface-dose-mean
  ref-comfort-dose-mean  
  
  ;; Bedienung und Grundeinstellungen
  Jahreszeit
  Stunde
  Zeitschritt
  protokoll-kopf-gedruckt?
  naechste-protokoll-stunde
  Auto-Update-Kartenansicht?
  taglauf-aktiv?
  Gebäudehöhe  
  Windgeschwindigkeit
  ;;   Baumhöhe
  ;;   Pinselgrösse
  ;;   Element
  ;;   Kartenansicht
  
  reset-scene?
  simulationszeit
  simulationsblock-aktiv?  
  solar-factor
  sun-elevation
  sun-azimuth
  air-temp
  relative-humidity
  Niederschlag-mm-pro-stunde
  gw-recharge-rasen-mm-pro-stunde
  gw-recharge-baum-mm-pro-stunde
  gw-recharge-hecke-mm-pro-stunde

  ;; Kennzahlen für Monitore
  Oberflächen-Temp
  hottest-temp
  shaded-share
  tree-share
  cool-share
  mean-station-temp
  hottest-station-temp
  coolest-station-temp
  tmin-luft
  tmax-luft
  oberflaeche-min-aktuell
  oberflaeche-max-aktuell
  oberflaeche-min-lauf
  oberflaeche-max-lauf

  ;; Messstationen
  next-station-id
  max-stations

  ;; Zustand der Maus
  mouse-was-down?
  
  Szenario-Name
  Aktive-Geometrie-Datei
]

; -----------------------------------------------------------------------------
; Eigene Variablen der Patches
; -----------------------------------------------------------------------------
; Jeder Patch repräsentiert eine kleine Fläche des Schulhofs. In diesem Block
; werden sowohl Materialeigenschaften als auch thermische Zustände, Wasser-
; variablen und Darstellungsgrößen gespeichert.
; -----------------------------------------------------------------------------
patches-own [
  shortwave-human 
  longwave-human 
  exposure-temp
  ;; Auswahlmarkierung eines Patches
  selected-area?  
  
  ;; Maxima und kumulierte Belastungsgrößen
  air-temp-local-max
  surface-temp-max
  comfort-index-max
  heat-dose-air
  heat-dose-surface
  heat-dose-comfort   ;; integrierte Hitzelast während der Schulzeit [äquivalente Belastungsstunden]
  water-store-rel
  water-stress-true  
  geom-done?
 
  ;; Wasserhaushalt und Feuchtezustand
  water-store             
  water-store-max
  water-stress
  wetness-factor
 
  ;; semantische Klassen und thermische Zustände
  substrate-temp
  Oberfläche
  ground-kind
  object-kind
  surface-temp
  air-temp-local
  air-temp-local-next
  albedo
  emissivity
  thermal-mass
  evap-factor

  ;; geometrische Eigenschaften und Kontextvariablen
  building-height
  veg-height
  roof-style
  wall-style
  shadow-level
  veg-nearby
  tree-nearby
  wall-exposure
  wall-height-local
  wall-albedo-local
  wall-green-local
  enclosedness
  comfort-index
  temp-delta
  heat-score-step

  ;; Referenzwerte für Vorher/Nachher-Vergleiche auf ausgewählten Flächen
  ref-active?
  ref-heat-dose-comfort
  ref-heat-dose-air
  ref-heat-dose-surface
  ref-comfort-index
  ref-comfort-index-max
  ref-shadow-level
]

; ----------------------------------------------------------------------------
; Zentrales Zeitmanagement
; ----------------------------------------------------------------------------
; Die Physik rechnet mit einem festen internen Zeitschritt, der nur im Code
; definiert ist. Ausgabe, Plot und Protokoll erfolgen ausschließlich zu vollen
; Stunden. Der interne Schritt wird hart auf den maximal stabilen Wert begrenzt.
; ----------------------------------------------------------------------------

to-report konfigurierte-physik-zeitschritt-stunden
  report 0.25
end

to-report maximal-zulaessiger-physik-zeitschritt-stunden
  report 0.25
end

to-report interner-zeitschritt-stunden
  let dt konfigurierte-physik-zeitschritt-stunden
  if not is-number? dt [ set dt 0.25 ]
  if dt <= 0 [ set dt 0.25 ]
  report min list dt maximal-zulaessiger-physik-zeitschritt-stunden
end

to synchronisiere-zeitschritt
  set Zeitschritt interner-zeitschritt-stunden
end

to-report ausgabeintervall-stunden
  report 1.0
end

to-report zeit-epsilon
  report 1.0E-9
end

to-report ist-volle-stunde? [t]
  report abs (t - round t) < zeit-epsilon
end

to-report naechste-volle-stunde [t]
  if ist-volle-stunde? t [ report min list 24 (round t + ausgabeintervall-stunden) ]
  report min list 24 (ceiling (t - zeit-epsilon))
end

to-report erste-protokoll-stunde [t]
  if ist-volle-stunde? t [ report max list 0 (round t) ]
  report min list 24 (ceiling (t - zeit-epsilon))
end

to-report zyklische-stunde [t]
  let tt t
  while [tt < 0] [
    set tt tt + 24
  ]
  while [tt > 24] [
    set tt tt - 24
  ]
  if ist-volle-stunde? tt [ set tt round tt ]
  report tt
end

to set-model-time [t]
  let tt t
  if tt < 0 [ set tt 0 ]
  if tt > 24 [ set tt 24 ]
  if ist-volle-stunde? tt [ set tt round tt ]
  set simulationszeit tt
  set Stunde tt
end

to physics-step [dt-hours]
  synchronisiere-zeitschritt
  let dt min list dt-hours (24 - simulationszeit)
  if dt <= 0 [ stop ]

  set-model-time (simulationszeit + dt)
  rebuild-derived-fields
  update-solar-geometry
  cast-shadows
  update-thermal-state dt
end


; ============================================================================
; Hauptablauf und Benutzerinteraktion
; ----------------------------------------------------------------------------
; Dieser Block bündelt die zentralen Einstiegspunkte des Modells. Hier wird das Modell 
; initialisiert, zeitlich fortgeschrieben und auf Benutzeraktionen aus dem Interface reagiert.
; ============================================================================

; ----------------------------------------------------------------------------
; setup
; Initialisiert das Modell vollständig, sichert Interface-Zustände, lädt die Weltgeometrie, 
; führt einen kurzen Spin-up der Meteorologie durch und bereitet Anzeigen, Stationen und Plots vor.
; ----------------------------------------------------------------------------
to setup
  ; --------------------------------------------------------------------------
  ; 1. Nutzerhinweis
  ; --------------------------------------------------------------------------
  print "Die Schule wird gebaut und der Anfangszustand berechnet. Ein bisschen Geduld ;-)."

  ; --------------------------------------------------------------------------
  ; 2. UI- und Zustandswerte sichern, die clear-all sonst löschen würde
  ; --------------------------------------------------------------------------
  let keep-reset-scene ifelse-value (is-boolean? reset-scene?) [ reset-scene? ] [ false ]

  let keep-view-mode ifelse-value (member? Kartenansicht [
    "Materialien & Elemente"
    "Schatten aktuell"
    "Oberflächentemperatur aktuell"
    "Lufttemperatur aktuell"
    "Hitzelast aktuell"
    "Hitzelast Schulzeit"
    "Hitzelast Änderung"
  ]) [ Kartenansicht ] [ "Materialien & Elemente" ]

  let keep-edit-mode ifelse-value (member? Element [
    "Station-setzen"
    "Station-entfernen"
    "Gebiet-auswählen"
    "Asphalt" "Pflaster" "Offenpflaster" "Sand" "Sportbelag" "Rasen"
    "Baum" "Hecke"
    "Gebäude" "Dach" "Dach-grün" "Wand" "Wand-grün"
    "Loeschen"
  ]) [ Element ] [ "Rasen" ]

  let keep-geom-file ifelse-value (is-string? Aktive-Geometrie-Datei) [ Aktive-Geometrie-Datei ] [ "" ]
  let keep-versuchsname ifelse-value (is-string? Versuchsname) [ Versuchsname ] [ "Standard" ]

  ; --------------------------------------------------------------------------
  ; 3. Alles zurücksetzen und gesicherte Schlüsselwerte wiederherstellen
  ; --------------------------------------------------------------------------
  clear-output
  clear-all

  set Aktive-Geometrie-Datei keep-geom-file
  set Versuchsname keep-versuchsname

  ; --------------------------------------------------------------------------
  ; 4. Namen und Basiseinstellungen normieren
  ; --------------------------------------------------------------------------
  if not is-string? Versuchsname [ set Versuchsname "Standard" ]
  if empty? trim Versuchsname [ set Versuchsname "Standard" ]
  set Szenario-Name trim Versuchsname

  set naechste-protokoll-stunde 0
  set protokoll-kopf-gedruckt? false
  set taglauf-aktiv? false
  set simulationsblock-aktiv? false
  reset-reference-comparison-globals

  set reset-scene? keep-reset-scene
  set Kartenansicht keep-view-mode
  set Element keep-edit-mode

  ; --------------------------------------------------------------------------
  ; 5. Weltgröße und globale Startwerte setzen
  ; --------------------------------------------------------------------------
  set-model-time 0
  synchronisiere-zeitschritt
  set Windgeschwindigkeit 2.0

  resize-world -25 25 -25 25
  set-patch-size 10
  
  apply-defaults

  ; --------------------------------------------------------------------------
  ; 6. Patch-Grundzustand initialisieren
  ; --------------------------------------------------------------------------
  ask patches [ initialise-patch ]
  set next-station-id 1
  set max-stations 5
  set mouse-was-down? false

  ; --------------------------------------------------------------------------
  ; 7. Modellparameter sichern, die durch Weltladen beeinflusst werden könnten
  ; --------------------------------------------------------------------------
  let keep-step interner-zeitschritt-stunden
  let keep-wind Windgeschwindigkeit
  let keep-season Jahreszeit

  ; --------------------------------------------------------------------------
  ; 8. Weltgeometrie laden
  ;    - entweder aus Szenariodatei
  ;    - oder aus der eingebauten Standardgeometrie
  ; --------------------------------------------------------------------------
  load-default-world

  ; --------------------------------------------------------------------------
  ; 9. Gewünschte Modellparameter nach dem Laden wieder herstellen
  ; --------------------------------------------------------------------------
  set Jahreszeit keep-season
  set Windgeschwindigkeit keep-wind
  set Zeitschritt keep-step

  ; --------------------------------------------------------------------------
  ; 10. Anfangszustand der geladenen Welt konsistent setzen
  ; --------------------------------------------------------------------------
  set-model-time 0
  set simulationsblock-aktiv? false
  set taglauf-aktiv? false
  if not is-boolean? protokoll-kopf-gedruckt? [ set protokoll-kopf-gedruckt? false ]

  ask patches [
    set air-temp-local-max air-temp-local
    set surface-temp-max surface-temp

    ifelse water-store-max > 0 [
      set water-store-rel water-store / water-store-max
    ] [
      set water-store-rel 0
    ]

    set water-stress-true 1 - water-stress
  ]

  rebuild-derived-fields
  update-solar-geometry
  cast-shadows

  ; --------------------------------------------------------------------------
  ; 11. Kurzer Spin-up, damit das Modell nicht mit einem unplausiblen
  ;     Startzustand losläuft
  ; --------------------------------------------------------------------------
  spin-up-local-meteo 0.25

  ; --------------------------------------------------------------------------
  ; 12. Nach dem Spin-up wieder sauber auf 00:00 zurücksetzen
  ; --------------------------------------------------------------------------
  set-model-time 0
  rebuild-derived-fields
  update-solar-geometry
  cast-shadows

  ask patches [
    set air-temp-local-max air-temp-local
    set surface-temp-max surface-temp
    set comfort-index-max comfort-index

    set heat-dose-air 0
    set heat-dose-surface 0
    set heat-dose-comfort 0

    ifelse water-store-max > 0 [
      set water-store-rel water-store / water-store-max
    ] [
      set water-store-rel 0
    ]

    set water-stress-true 1 - water-stress
  ]

  ; --------------------------------------------------------------------------
  ; 13. Globale Kennwerte initialisieren
  ; --------------------------------------------------------------------------
  set tmin-luft air-temp
  set tmax-luft air-temp
  set oberflaeche-min-aktuell min [surface-temp] of patches
  set oberflaeche-max-aktuell max [surface-temp] of patches
  set oberflaeche-min-lauf oberflaeche-min-aktuell
  set oberflaeche-max-lauf oberflaeche-max-aktuell

  ; --------------------------------------------------------------------------
  ; 14. Demo-Stationen, Plot und Anzeigen aufbauen
  ; --------------------------------------------------------------------------
  setup-demo-stations
  update-indicators
  update-station-readings
  setup-station-plot
  update-station-plot
;setup-hitzelastklassen-plot
;update-hitzelastklassen-plot
  ; --------------------------------------------------------------------------
  ; 15. Darstellung abschließen
  ; --------------------------------------------------------------------------
  reset-ticks
  recolor-world
  refresh-station-appearance
  display
   szenarien-anzeigen
  user-message "Simulation ist startklar."
end

; ----------------------------------------------------------------------------
; go
; Führt einen einzelnen Zeitschritt des allgemeinen Modelllaufs aus und 
; aktualisiert danach alle abgeleiteten Anzeigen.
; ----------------------------------------------------------------------------

to go
  if simulationszeit >= 24 - zeit-epsilon [ stop ]

  synchronisiere-zeitschritt
  let dt min list interner-zeitschritt-stunden (24 - simulationszeit)
  physics-step dt
  recolor-world
  refresh-station-appearance
  update-indicators
  update-station-readings
  update-station-plot
  ;update-hitzelastklassen-plot
  tick-advance dt
end

; ----------------------------------------------------------------------------
; interaktiv
; Aktualisiert das Modell nach interaktiven Eingriffen mit der Maus, 
; ohne einen vollen Zeitschritt der Simulation durchzuführen.
; ----------------------------------------------------------------------------
to interaktiv
  handle-mouse-edit
  rebuild-derived-fields
  cast-shadows
  recolor-world
  draw-selection-overlay
  refresh-station-appearance
  update-indicators
  update-station-readings
  ;update-hitzelastklassen-plot
  display
end

; ----------------------------------------------------------------------------
; refresh-display
; Berechnet alle abgeleiteten Felder und Anzeigegrößen neu, ohne die Zeit voranzuschieben.
; ----------------------------------------------------------------------------
to refresh-display
  rebuild-derived-fields
  cast-shadows
  recolor-world
  refresh-station-appearance
  update-indicators
  update-station-readings
  display
end


; ----------------------------------------------------------------------------
; lauf-neu-vorbereiten
; Setzt nur die dynamischen Tageslaufgrößen zurück.
; Geometrie, Gebietsauswahl, Stationen und gespeicherte Referenz bleiben erhalten.
; Dieser Einstieg ist für Vorher/Nachher-Vergleiche gedacht: nach einer Maßnahme
; wird damit ein neuer Tageslauf gestartet, ohne die Auswahlfläche zu verlieren.
; ----------------------------------------------------------------------------
to lauf-neu-vorbereiten
  set simulationsblock-aktiv? false
  set taglauf-aktiv? false
  set protokoll-kopf-gedruckt? false
  set naechste-protokoll-stunde 0

  set-model-time 0
  synchronisiere-zeitschritt
  update-solar-geometry

  ask patches [
    ;; Semantik beibehalten, aber Material- und Wasserspeicherzustand für den neuen Lauf
    ;; konsistent neu setzen. selected-area? und ref-* werden absichtlich nicht angefasst.
    sync-patch-semantics
    set surface-temp air-temp
    set substrate-temp air-temp
    set air-temp-local air-temp
    set air-temp-local-next air-temp

    set air-temp-local-max air-temp-local
    set surface-temp-max surface-temp
    set comfort-index-max 0

    set heat-dose-air 0
    set heat-dose-surface 0
    set heat-dose-comfort 0
    set heat-score-step 0

    ifelse water-store-max > 0 [
      set water-store-rel water-store / water-store-max
    ] [
      set water-store-rel 0
    ]
    set water-stress-true 1 - water-stress
  ]

  rebuild-derived-fields
  update-solar-geometry
  cast-shadows
  recolor-world
  draw-selection-overlay
  refresh-station-appearance
  update-indicators
  update-station-readings
  setup-station-plot
  ;update-hitzelastklassen-plot
  reset-ticks
  display
  print "Neuer Tageslauf vorbereitet. Auswahl und Referenz wurden nicht gelöscht."
end


to massnahme-aktivieren
  ;; Desktop- und Web-kompatibler Vorher/Nachher-Workflow.
  ;; Es wird KEINE Datei geschrieben.
  ;; Die Referenz wird nur in den ref-* Patchvariablen gemerkt.
  ;;
  ;; Zweck:
  ;; 1. Nach Lauf 1 aktuellen Zustand als Vorher-Referenz merken.
  ;; 2. Tageswerte zurücksetzen.
  ;; 3. Geometrie, Auswahl, Stationen und Referenz behalten.
  ;; 4. Danach kann die Maßnahme gesetzt und Lauf 2 gestartet werden.

  if not ref-selection-saved? [
    if simulationszeit < 24 - zeit-epsilon [
      user-message "Der erste Versuch ist noch nicht vollständig bis 24:00 gelaufen. Erst 'Versuch starten' bis zum Ende laufen lassen."
      stop
    ]

    referenz-speichern
    print "Vorher-Zustand für den Vergleich gemerkt."
  ]

  lauf-neu-vorbereiten
  print "Maßnahme kann jetzt gesetzt werden. Danach 'Versuch starten' erneut ausführen."
end
; ----------------------------------------------------------------------------
; simulieren
; Führt den schrittweisen Tageslauf aus, inklusive Plotfortschreibung und textlicher Protokollierung voller Stunden.
; ----------------------------------------------------------------------------
to simulieren
  synchronisiere-zeitschritt

  if not simulationsblock-aktiv? [
    set protokoll-kopf-gedruckt? false
    set naechste-protokoll-stunde erste-protokoll-stunde simulationszeit
    set simulationsblock-aktiv? true

    update-indicators
    update-station-readings
    setup-station-plot
    if ist-volle-stunde? simulationszeit [
      update-station-plot
      protokolliere-faellige-stunden
    ]
    display
    szenarien-anzeigen
  ]

  if simulationszeit >= 24 [
    set simulationsblock-aktiv? false
    stop
  ]

  let start-time simulationszeit
  let target-time naechste-volle-stunde simulationszeit

  while [simulationszeit < target-time - zeit-epsilon] [
    let dt min list interner-zeitschritt-stunden (target-time - simulationszeit)
    physics-step dt
  ]

  if ist-volle-stunde? simulationszeit [
    set-model-time round simulationszeit
  ]

  recolor-world
  refresh-station-appearance
  update-indicators
  update-station-readings
  update-station-plot
  protokolliere-faellige-stunden
  ;update-hitzelastklassen-plot
  display
  tick-advance (simulationszeit - start-time)

  if simulationszeit >= 24 [
    szenarien-anzeigen
      if not ref-selection-saved? [
    referenz-speichern
    print "Referenz automatisch gespeichert (Ende Lauf 1)."
  ]
    set simulationsblock-aktiv? false
    stop
  ]
  
end

to-report hitzelast-legende-horizontal
  report (word
    "  b :" precision prozent-hitzelast-blau 0 "% | "
    "gr: " precision prozent-hitzelast-gruen 0 "% | "
    "ge: " precision prozent-hitzelast-gelb 0 "% | "
    "o : " precision prozent-hitzelast-orange 0 "% | "
    "r : " precision prozent-hitzelast-rot 0 "% "
  )
end
to-report hitzelast-legende-vertikal
  report (word
    "blau <=1 h: " precision prozent-hitzelast-blau 0 "%" "\n"
    "grün 1-2.5 h: " precision prozent-hitzelast-gruen 0 "%" "\n"
    "gelb 2.5-5 h: " precision prozent-hitzelast-gelb 0 "%" "\n"
    "orange 5-6.5 h: " precision prozent-hitzelast-orange 0 "%" "\n"
    "rot >6.5 h: " precision prozent-hitzelast-rot 0 "%"
  )
end
; ----------------------------------------------------------------------------
; simuliere-tag
; Lässt einen kompletten Tag automatisch durchlaufen.
; ----------------------------------------------------------------------------
to simuliere-tag
  if not is-boolean? taglauf-aktiv? [
    set taglauf-aktiv? false
  ]
  if not is-boolean? simulationsblock-aktiv? [
    set simulationsblock-aktiv? false
  ]

  if taglauf-aktiv? [ stop ]
  set taglauf-aktiv? true

  lauf-neu-vorbereiten
  set simulationsblock-aktiv? false
  while [simulationszeit < 24 - zeit-epsilon] [
    simulieren
  ]
  set simulationsblock-aktiv? false
  set taglauf-aktiv? false
end


; ----------------------------------------------------------------------------
; Kartenansicht-aktualisieren
; Aktualisiert Kartenansicht und Stationswerte ohne Zeitschritt.
; ----------------------------------------------------------------------------
to Kartenansicht-aktualisieren
  rebuild-derived-fields
  cast-shadows
  recolor-world
  refresh-station-appearance
  update-indicators
  update-station-readings
  display
end

; ============================================================================
; Dieser Block enthält die Funktionen, die Standardwerte absichern, 
; Reset-Szenarien herstellen und über Buttons aufrufbare Komfortabläufe kapseln.
; ============================================================================

; ----------------------------------------------------------------------------
; apply-defaults
; Sichert Standardwerte für alle zentralen Steuerungsvariablen, falls sie im Interface oder durch alte Zustände fehlen oder ungültig sind.
; ----------------------------------------------------------------------------
to apply-defaults
  if not is-boolean? mouse-was-down? [ set mouse-was-down? false ]
  ;if not is-string? Aktive-Geometrie-Datei [ set Aktive-Geometrie-Datei "" ]
  if not is-boolean? Legende-an? [ set Legende-an? false ]
  if not (member? Jahreszeit ["Sommer" "Frühling/Herbst" "Winter"]) [ set Jahreszeit "Sommer" ]
  if not is-number? Stunde                    [ set-model-time 13 ]
  if not is-number? simulationszeit           [ set-model-time Stunde ]
  synchronisiere-zeitschritt
  if not is-number? Windgeschwindigkeit       [ set Windgeschwindigkeit 2 ]
  if not is-number? relative-humidity         [ set relative-humidity 55 ]
  if not is-number? Niederschlag-mm-pro-stunde [ set Niederschlag-mm-pro-stunde 0 ]
  if not is-number? gw-recharge-rasen-mm-pro-stunde [ set gw-recharge-rasen-mm-pro-stunde 0.03 ]
  if not is-number? gw-recharge-baum-mm-pro-stunde  [ set gw-recharge-baum-mm-pro-stunde 0.05 ]
  if not is-number? gw-recharge-hecke-mm-pro-stunde [ set gw-recharge-hecke-mm-pro-stunde 0.04 ]
  if not is-number? Gebäudehöhe               [ set Gebäudehöhe 8 ]
  if not is-number? Baumhöhe                  [ set Baumhöhe 7 ]
  if not is-number? Pinselgrösse               [ set Pinselgrösse 1 ]

  if not (member? Element [
    "Station-setzen" "Station-entfernen"
    "Gebiet-auswählen"
    "Asphalt" "Pflaster" "Offenpflaster" "Sand" "Sportbelag" "Rasen"
    "Baum" "Hecke" 
    "Gebäude"  "Dach" "Dach-grün" "Wand" "Wand-grün"
    "Loeschen"
  ]) [ set Element "Rasen" ]

if Kartenansicht = "Temperatur" [ set Kartenansicht "Lufttemperatur aktuell" ]

if Kartenansicht = "Oberfläche" [ set Kartenansicht "Materialien & Elemente" ]
if Kartenansicht = "Schatten" [ set Kartenansicht "Schatten aktuell" ]
if Kartenansicht = "T-Oberfläche" [ set Kartenansicht "Oberflächentemperatur aktuell" ]
if Kartenansicht = "T-Luft" [ set Kartenansicht "Lufttemperatur aktuell" ]
if Kartenansicht = "Belastung" [ set Kartenansicht "Hitzelast aktuell" ]
if Kartenansicht = "Hitzebelastung" [ set Kartenansicht "Hitzelast Schulzeit" ]
if not (member? Kartenansicht [
  "Materialien & Elemente"
  "Schatten aktuell"
  "Oberflächentemperatur aktuell"
  "Lufttemperatur aktuell"
  "Hitzelast aktuell"
  "Hitzelast Schulzeit"
  "Hitzelast Änderung"
]) [ set Kartenansicht "Materialien & Elemente" ]
  
  if not is-boolean? reset-scene? [ set reset-scene? false ]
end


; -----------------------------------------------------------------------------
; Szenenaufbau
; -----------------------------------------------------------------------------


; ----------------------------------------------------------------------------
; reset-demo
; Stellt den Demo-Ausgangszustand her.
; ----------------------------------------------------------------------------
to reset-demo
  set reset-scene? false
  set Kartenansicht "Materialien & Elemente"
  setup
end



; ----------------------------------------------------------------------------
; midday
; Springt auf Mittagsbedingungen und berechnet die Anzeigegrößen neu.
; ----------------------------------------------------------------------------
to midday
  set simulationsblock-aktiv? false
  set-model-time 13
  rebuild-derived-fields
  update-solar-geometry
  cast-shadows
  recolor-world
  update-indicators
  update-station-readings
end

; ----------------------------------------------------------------------------
; morning
; Springt auf Morgenbedingungen und berechnet die Anzeigegrößen neu.
; ----------------------------------------------------------------------------
to morning
  set simulationsblock-aktiv? false
  set-model-time 9
  rebuild-derived-fields
  update-solar-geometry
  cast-shadows
  recolor-world
  update-indicators
  update-station-readings
end

; ----------------------------------------------------------------------------
; evening
; Springt auf Abendbedingungen und berechnet die Anzeigegrößen neu.
; ----------------------------------------------------------------------------
to evening
  set simulationsblock-aktiv? false
  set-model-time 17
  rebuild-derived-fields
  update-solar-geometry
  cast-shadows
  recolor-world
  update-indicators
  update-station-readings
end

; ----------------------------------------------------------------------------
; morgen
; Button-Wrapper für morning.
; ----------------------------------------------------------------------------
to morgen
  morning
end

; ----------------------------------------------------------------------------
; mittag
; Button-Wrapper für midday.
; ----------------------------------------------------------------------------
to mittag
  midday
end

; ----------------------------------------------------------------------------
; abend
; Button-Wrapper für evening.
; ----------------------------------------------------------------------------
to abend
  evening
end

; ----------------------------------------------------------------------------
; bearbeiten
; Button-Wrapper für die interaktive Kartenbearbeitung.
; ----------------------------------------------------------------------------
to bearbeiten
  interaktiv
end

; ----------------------------------------------------------------------------
; stationen-neu
; Button-Wrapper für clear-stations.
; ----------------------------------------------------------------------------
to stationen-neu
  clear-stations
end

; ============================================================================
; Szenenaufbau, Weltaufbau und Geometrie laden
; ----------------------------------------------------------------------------
; Hier werden Ausgangswelten und Demo-Szenarien erzeugt oder aus der rechteckbasierten Geometriebeschreibung wieder aufgebaut.
; ============================================================================

; ----------------------------------------------------------------------------
; setup-empty-schoolyard
; Erzeugt einen leeren Referenzschulhof mit Pflasterfläche und ohne zusätzliche Objekte.
; ----------------------------------------------------------------------------
to setup-empty-schoolyard
  ask patches [
    set-ground-kind "Pflaster"
    set-object-kind "none"
  ]
  display
end

; ----------------------------------------------------------------------------
; setup-demo-stations
; Setzt die vorgesehenen Demo-Messstationen an feste Orte und aktualisiert ihre Auslesewerte.
; ----------------------------------------------------------------------------
to setup-demo-stations
  clear-stations
  Station-setzen patch 10 -9
  Station-setzen patch -2 11
  Station-setzen patch 16 16
  update-station-readings
end

; ----------------------------------------------------------------------------
; setup-demo-schoolyard
; Baut einen vorbereiteten Demo-Schulhof mit Gebäuden, Sportbelag, Vegetation und vorbereiteten Dach- und Wandstilen auf.
; ----------------------------------------------------------------------------
to setup-demo-schoolyard
  ask patches [
    set-ground-kind "Pflaster"
    set-object-kind "none"
  ]

  paint-rect -40 -16 -12 20 "Gebaeude"
  paint-rect 16 40 -8 24 "Gebaeude"
  paint-rect -10 10 28 40 "Gebaeude"

  ask patches with [object-kind = "building" and pxcor >= 16] [
    set building-height 10
    sync-patch-semantics
  ]

  paint-rect -12 12 -40 -20 "Sportbelag"
  paint-rect 24 44 -44 -24 "Asphalt"
  paint-rect -48 -32 -44 -24 "Hecke"
  paint-rect -48 -36 28 44 "Rasen"
  paint-rect -4 4 18 24 "Sand"

  ask patch -30 -28 [ set-object-kind "tree" ]
  ask patch -24 36 [ set-object-kind "tree" ]
  ask patch 30 36 [ set-object-kind "tree" ]
  ask patch -6 -4 [ set-object-kind "tree" ]
  ask patch 6 -4 [ set-object-kind "tree" ]

  ask patches with [object-kind = "building" and pxcor < -16] [ apply-roof-style "normal-roof" apply-wall-style "green-wall" ]
  ask patches with [object-kind = "building" and pxcor > 15] [ apply-roof-style "green-roof" apply-wall-style "green-wall" ]
  ask patches with [object-kind = "building" and pycor >= 28] [ apply-wall-style "normal-wall" ]
  rebuild-derived-fields
cast-shadows
recolor-world
refresh-station-appearance
update-indicators
update-station-readings
display
end

; ----------------------------------------------------------------------------
; paint-rect
; Hilfsfunktion zum Setzen eines rechteckigen Bereichs mit einer gegebenen Oberflächen- oder Objektklasse.
; ----------------------------------------------------------------------------
to paint-rect [x1 x2 y1 y2 kind]
  ask patches with [pxcor >= x1 and pxcor <= x2 and pycor >= y1 and pycor <= y2] [
    set-Oberfläche kind
  ]
end

; ----------------------------------------------------------------------------
; load-default-world
; Lädt die Referenzwelt aus der Rechteckgeometrie und setzt Plot- sowie Stationszustände auf einen sauberen Start zurück.
; ----------------------------------------------------------------------------
to load-default-world
  ifelse is-string? Aktive-Geometrie-Datei and
         Aktive-Geometrie-Datei != "" and
         file-exists? Aktive-Geometrie-Datei [
    file-close-all
    file-open Aktive-Geometrie-Datei
    let rects file-read
    file-close
    build-world-from-rects rects
  ] [
    build-world-from-rects geometry-rects-half
  ]

  ask patches [
    set plabel ""
    set plabel-color black
  ]

  set next-station-id 1

  set-current-plot "Stationen Temperatur"
  clear-plot
end

to reset-demo-szenario
  set reset-scene? false
  set Kartenansicht "Materialien & Elemente"

  synchronisiere-szenario-name
  let fname (word "scenario_" trim Szenario-Name "_geom.txt")

  ifelse file-exists? fname [
    set Aktive-Geometrie-Datei fname
  ] [
    set Aktive-Geometrie-Datei ""
  ]

  setup
end

